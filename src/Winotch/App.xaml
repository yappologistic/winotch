<Application
    x:Class="Winotch.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winotch"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <!-- Reference-matched Fluent material palette. The backdrop itself is native
                 Desktop Acrylic; these translucent layers tune contrast over any wallpaper. -->
            <FontFamily x:Key="WinotchTextFont">Segoe UI Variable Text, Segoe UI</FontFamily>
            <FontFamily x:Key="WinotchDisplayFont">Segoe UI Variable Display, Segoe UI</FontFamily>
            <FontFamily x:Key="WinotchIconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

            <Color x:Key="WinotchFallbackColor">#E63B4C69</Color>
            <Color x:Key="WinotchSurfaceColor">#8A304564</Color>
            <Color x:Key="WinotchSurfaceRaisedColor">#B33B506F</Color>
            <Color x:Key="WinotchSurfaceHoverColor">#CC4B6180</Color>
            <Color x:Key="WinotchSurfacePressedColor">#E0576D8C</Color>
            <Color x:Key="WinotchStrokeColor">#47FFFFFF</Color>
            <Color x:Key="WinotchTextColor">#FFFFFFFF</Color>
            <Color x:Key="WinotchMutedTextColor">#C9E7ECF5</Color>
            <Color x:Key="WinotchSubtleTextColor">#91D8E0ED</Color>
            <Color x:Key="WinotchAccentColor">#FF60CDFF</Color>
            <Color x:Key="WinotchSuccessColor">#FF6CCB5F</Color>
            <Color x:Key="WinotchWarningColor">#FFFFB84D</Color>
            <Color x:Key="WinotchDangerColor">#FFFF6B63</Color>

            <SolidColorBrush x:Key="NotchBlack" Color="{StaticResource WinotchFallbackColor}" />
            <SolidColorBrush x:Key="NotchPanel" Color="{StaticResource WinotchSurfaceColor}" />
            <SolidColorBrush x:Key="NotchPanelRaised" Color="{StaticResource WinotchSurfaceRaisedColor}" />
            <SolidColorBrush x:Key="NotchPanelHover" Color="{StaticResource WinotchSurfaceHoverColor}" />
            <SolidColorBrush x:Key="NotchPanelPressed" Color="{StaticResource WinotchSurfacePressedColor}" />
            <SolidColorBrush x:Key="NotchStroke" Color="{StaticResource WinotchStrokeColor}" />
            <SolidColorBrush x:Key="NotchAccent" Color="{StaticResource WinotchAccentColor}" />
            <SolidColorBrush x:Key="NotchSuccess" Color="{StaticResource WinotchSuccessColor}" />
            <SolidColorBrush x:Key="NotchWarning" Color="{StaticResource WinotchWarningColor}" />
            <SolidColorBrush x:Key="NotchDanger" Color="{StaticResource WinotchDangerColor}" />
            <SolidColorBrush x:Key="NotchText" Color="{StaticResource WinotchTextColor}" />
            <SolidColorBrush x:Key="NotchMutedText" Color="{StaticResource WinotchMutedTextColor}" />
            <SolidColorBrush x:Key="NotchSubtleText" Color="{StaticResource WinotchSubtleTextColor}" />

            <CornerRadius x:Key="WinotchPillCornerRadius">0,0,32,32</CornerRadius>
            <CornerRadius x:Key="WinotchCardCornerRadius">14</CornerRadius>
            <Thickness x:Key="WinotchHairline">1</Thickness>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource WinotchTextFont}" />
                <Setter Property="Foreground" Value="{StaticResource NotchText}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="IconText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource WinotchIconFont}" />
                <Setter Property="Foreground" Value="{StaticResource NotchText}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="WinotchCaptionText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource NotchMutedText}" />
            </Style>

            <Style x:Key="WinotchBodyText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="WinotchDisplayText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource WinotchDisplayFont}" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource WinotchTextFont}" />
                <Setter Property="Foreground" Value="{StaticResource NotchText}" />
                <Setter Property="Background" Value="{StaticResource NotchPanel}" />
                <Setter Property="BorderBrush" Value="{StaticResource NotchStroke}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="12,7" />
            </Style>

            <Style x:Key="WinotchIconButton" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource NotchText}" />
            </Style>

            <Style x:Key="MediaIconButton" TargetType="Button" BasedOn="{StaticResource WinotchIconButton}">
                <Setter Property="Margin" Value="2" />
            </Style>

            <Style x:Key="NotchListBoxItem" TargetType="ListViewItem">
                <Setter Property="Padding" Value="10,7" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="CornerRadius" Value="9" />
            </Style>

            <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
                <Setter Property="Height" Value="4" />
                <Setter Property="Background" Value="{StaticResource NotchStroke}" />
                <Setter Property="Foreground" Value="{StaticResource NotchAccent}" />
                <Setter Property="CornerRadius" Value="2" />
            </Style>

            <Style x:Key="ModernSlider" TargetType="Slider">
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Foreground" Value="{StaticResource NotchAccent}" />
            </Style>

            <Style x:Key="NotchTextBox" TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource WinotchTextFont}" />
                <Setter Property="Foreground" Value="{StaticResource NotchText}" />
                <Setter Property="Background" Value="{StaticResource NotchPanel}" />
                <Setter Property="BorderBrush" Value="{StaticResource NotchStroke}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="9" />
                <Setter Property="Padding" Value="10,6" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
