<UserControl
    x:Class="Winotch.ClipboardHistoryPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winotch"
    UseLayoutRounding="True">
    <StackPanel>
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="{StaticResource NotchMutedText}"
                Text="Clipboard" />
            <Button
                x:Name="ClearClipboardButton"
                Grid.Column="1"
                Width="28"
                Height="28"
                Padding="0"
                AutomationProperties.Name="Clear clipboard history"
                Click="ClearClipboard_Click"
                ToolTipService.ToolTip="Clear">
                <TextBlock
                    FontSize="12"
                    Style="{StaticResource IconText}"
                    Text="&#xE894;" />
            </Button>
        </Grid>

        <TextBlock
            x:Name="EmptyClipboardText"
            Margin="0,4,0,0"
            FontSize="12"
            Foreground="{StaticResource NotchMutedText}"
            Text="Clipboard history is empty" />

        <ListView
            x:Name="ClipboardList"
            Height="150"
            Background="Transparent"
            BorderThickness="0"
            Foreground="{StaticResource NotchText}"
            IsItemClickEnabled="True"
            ItemClick="ClipboardItem_Click"
            ItemContainerStyle="{StaticResource NotchListBoxItem}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ClipboardHistoryRow">
                    <Grid MinHeight="38" Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="30" />
                        </Grid.ColumnDefinitions>

                        <Grid
                            Grid.Column="0"
                            Width="22"
                            Height="22"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Style="{StaticResource IconText}"
                                Text="{Binding Glyph}"
                                Visibility="{Binding GlyphVisibility}" />
                            <Image
                                Width="22"
                                Height="22"
                                Source="{Binding Icon}"
                                Stretch="UniformToFill"
                                Visibility="{Binding IconVisibility}" />
                        </Grid>

                        <Grid Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Text="{Binding Preview}"
                                TextTrimming="CharacterEllipsis"
                                Visibility="{Binding PreviewVisibility}" />
                            <Image
                                MaxWidth="64"
                                MaxHeight="56"
                                HorizontalAlignment="Left"
                                Source="{Binding Thumbnail}"
                                Stretch="Uniform"
                                Visibility="{Binding ThumbnailVisibility}" />
                        </Grid>

                        <TextBlock
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{StaticResource NotchMutedText}"
                            Text="{Binding TimeText}" />

                        <TextBlock
                            Grid.Column="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="{StaticResource NotchAccent}"
                            Style="{StaticResource IconText}"
                            Text="{Binding ConfirmationGlyph}" />

                        <Button
                            Grid.Column="4"
                            Width="26"
                            Height="26"
                            Padding="0"
                            AutomationProperties.Name="Copy clipboard history item"
                            Click="ClipboardCopyButton_Click"
                            Tag="{Binding Entry}"
                            ToolTipService.ToolTip="Copy">
                            <TextBlock
                                FontSize="11"
                                Style="{StaticResource IconText}"
                                Text="&#xE8C8;" />
                        </Button>

                        <Button
                            Grid.Column="5"
                            Width="26"
                            Height="26"
                            Padding="0"
                            Opacity="0.72"
                            AutomationProperties.Name="Delete clipboard history item"
                            Click="DeleteClipboardItem_Click"
                            Tag="{Binding Entry}"
                            ToolTipService.ToolTip="Delete">
                            <TextBlock
                                FontSize="11"
                                Style="{StaticResource IconText}"
                                Text="&#xE74D;" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</UserControl>
