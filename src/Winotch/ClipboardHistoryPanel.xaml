<UserControl x:Class="Winotch.ClipboardHistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Winotch"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <StackPanel>
        <DockPanel Margin="0,0,0,8">
            <Button x:Name="ClearClipboardButton"
                    DockPanel.Dock="Right"
                    Width="28"
                    Height="28"
                    Padding="0"
                    ToolTip="Clear"
                    AutomationProperties.Name="Clear clipboard history"
                    Click="ClearClipboard_Click">
                <TextBlock Style="{StaticResource IconText}" Text="&#xE894;" FontSize="12" />
            </Button>
            <TextBlock Text="Clipboard" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
        </DockPanel>

        <TextBlock x:Name="EmptyClipboardText"
                   Text="Clipboard history is empty"
                   FontSize="12"
                   Foreground="{StaticResource NotchMutedText}"
                   Margin="0,4,0,0" />

        <ListBox x:Name="ClipboardList"
                 Height="150"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="{StaticResource NotchText}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ItemContainerStyle="{StaticResource NotchListBoxItem}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type local:ClipboardHistoryRow}">
                    <Border Background="Transparent"
                            Cursor="Hand"
                            Tag="{Binding Entry}"
                            MouseLeftButtonUp="ClipboardItem_Click">
                        <Grid MinHeight="34" Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="26" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding Glyph}"
                                       Style="{StaticResource IconText}"
                                       FontSize="14"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center" />

                            <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                <TextBlock x:Name="PreviewText"
                                           Text="{Binding Preview}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <Image x:Name="ThumbnailImage"
                                       Source="{Binding Thumbnail}"
                                       MaxWidth="64"
                                       MaxHeight="56"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Left"
                                       Visibility="Collapsed" />
                            </Grid>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding TimeText}"
                                       FontSize="11"
                                       Foreground="{StaticResource NotchMutedText}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />

                            <TextBlock Grid.Column="3"
                                       Text="{Binding ConfirmationGlyph}"
                                       Style="{StaticResource IconText}"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <Button x:Name="DeleteClipboardButton"
                                    Grid.Column="4"
                                    Width="24"
                                    Height="24"
                                    Padding="0"
                                    Opacity="0"
                                    Tag="{Binding Entry}"
                                    ToolTip="Delete"
                                    AutomationProperties.Name="Delete clipboard history item"
                                    Click="DeleteClipboardItem_Click">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE74D;" FontSize="11" />
                            </Button>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                            <Setter TargetName="PreviewText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ThumbnailImage" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                            <Setter TargetName="DeleteClipboardButton" Property="Opacity" Value="1" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</UserControl>
