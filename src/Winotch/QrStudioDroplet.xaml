<Window x:Class="Winotch.QrStudioDroplet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QR studio"
        Width="360"
        Height="360"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">
    <Border x:Name="FlyoutChrome" Padding="10" CornerRadius="24" Background="{StaticResource NotchBlack}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" RenderTransformOrigin="0.5,0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="FlyoutScale" ScaleX="0.96" ScaleY="0.96" />
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="78" />
                <RowDefinition Height="*" />
                <RowDefinition Height="38" />
            </Grid.RowDefinitions>
            <Grid Margin="2,0,2,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8B3;" FontSize="15" Margin="0,0,8,0" />
                    <TextBlock Text="QR" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource MediaIconButton}" Width="28" Height="28" Margin="0" ToolTip="Close" AutomationProperties.Name="Close QR studio" Click="CloseButton_Click">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE711;" FontSize="10" />
                </Button>
            </Grid>
            <TextBox x:Name="QrInputBox" Grid.Row="1" Style="{StaticResource NotchTextBox}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="12" TextChanged="QrInputBox_TextChanged" />
            <Border Grid.Row="2" Margin="0,10,0,8" CornerRadius="8" Background="{StaticResource NotchPanel}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1">
                <Grid>
                    <Image x:Name="QrImage" Width="168" Height="168" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock x:Name="QrErrorText" FontSize="12" Foreground="{StaticResource NotchMutedText}" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="22" />
                </Grid>
            </Border>
            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <Button Content="Paste" Padding="11,6" Margin="0,0,8,0" Click="PasteButton_Click" />
                <Button Content="Copy PNG" Padding="11,6" Click="CopyPngButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
