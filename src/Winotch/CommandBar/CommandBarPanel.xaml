<UserControl x:Class="Winotch.CommandBar.CommandBarPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="248"
             Focusable="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBox x:Name="CommandInputBox"
                 Style="{StaticResource NotchTextBox}"
                 Background="{StaticResource NotchPanel}"
                 BorderBrush="{StaticResource NotchStroke}"
                 Height="54"
                 FontSize="15"
                 Padding="14,0"
                 VerticalContentAlignment="Center"
                 AutomationProperties.Name="Command" />

        <ListBox x:Name="CommandResultsList"
                 Grid.Row="1"
                 Margin="0,10,0,0"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{StaticResource NotchText}"
                 ItemContainerStyle="{StaticResource NotchListBoxItem}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid MinHeight="50">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="24" Height="24" CornerRadius="7" Background="{StaticResource NotchPanel}" VerticalAlignment="Center">
                            <Grid>
                                <Image x:Name="ResultIcon" Source="{Binding Icon}" Width="22" Height="22" Stretch="UniformToFill" Visibility="Collapsed" />
                                <TextBlock x:Name="ResultGlyph" Text="{Binding Glyph}" Style="{StaticResource IconText}" FontSize="12" Foreground="{StaticResource NotchMutedText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Subtitle}"
                                       FontSize="11"
                                       Foreground="{StaticResource NotchMutedText}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ProviderName}"
                                   MaxWidth="112"
                                   FontSize="11"
                                   Foreground="{StaticResource NotchMutedText}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   Margin="16,0,0,0" />
                    </Grid>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding HasIcon}" Value="True">
                            <Setter TargetName="ResultIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ResultGlyph" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>

