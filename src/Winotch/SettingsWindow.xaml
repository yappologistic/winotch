<local:FluentWindow
    x:Class="Winotch.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winotch"
    Title="Winotch Settings"
    Width="640"
    Height="780"
    ShowInTaskbar="True"
    Topmost="False"
    UseOverlayChrome="False"
    UseWindowRegion="False"
    BottomCornerRadius="12">
    <local:FluentWindow.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </local:FluentWindow.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.Resources>
            <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource WinotchDisplayFont}" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource NotchText}" />
                <Setter Property="Margin" Value="0,0,0,16" />
            </Style>

            <Style x:Key="SettingsCard" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource NotchPanel}" />
                <Setter Property="BorderBrush" Value="{StaticResource NotchStroke}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource WinotchCardCornerRadius}" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="Margin" Value="0,0,0,16" />
            </Style>

            <Style x:Key="SettingsToggle" TargetType="ToggleSwitch">
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="OffContent" Value="{x:Null}" />
                <Setter Property="OnContent" Value="{x:Null}" />
                <Setter Property="MinWidth" Value="44" />
            </Style>

            <Style x:Key="SettingsLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="SettingsDescription" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{StaticResource NotchMutedText}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SettingsRow" TargetType="Grid">
                <Setter Property="MinHeight" Value="40" />
            </Style>
        </Grid.Resources>

        <ScrollViewer
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,36">
                <TextBlock
                    FontFamily="{StaticResource WinotchDisplayFont}"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="Winotch Settings" />
                <TextBlock
                    Margin="0,5,0,26"
                    Foreground="{StaticResource NotchMutedText}"
                    FontSize="13"
                    Text="Personalize the notch and choose which local integrations are active." />

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SettingsSectionHeader}" Text="General" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="24-hour clock" />
                            <ToggleSwitch x:Name="Use24HourClockToggle" AutomationProperties.Name="24-hour clock" Style="{StaticResource SettingsToggle}" Toggled="GeneralSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Show date" />
                            <ToggleSwitch x:Name="ShowDateToggle" AutomationProperties.Name="Show date" Style="{StaticResource SettingsToggle}" Toggled="GeneralSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Start with Windows" />
                            <ToggleSwitch x:Name="StartWithWindowsToggle" AutomationProperties.Name="Start with Windows" Style="{StaticResource SettingsToggle}" Toggled="StartWithWindowsChanged" />
                        </Grid>
                        <TextBlock
                            x:Name="StartupStatusText"
                            Style="{StaticResource SettingsDescription}"
                            Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SettingsSectionHeader}" Text="Features" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Clipboard capture" />
                            <ToggleSwitch x:Name="ClipboardHistoryEnabledToggle" AutomationProperties.Name="Clipboard capture" Style="{StaticResource SettingsToggle}" Toggled="FeatureSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Per-app audio mixer" />
                            <ToggleSwitch x:Name="ShowAppMixerToggle" AutomationProperties.Name="Per-app audio mixer" Style="{StaticResource SettingsToggle}" Toggled="FeatureSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="System stats sampling" />
                            <ToggleSwitch x:Name="SystemStatsEnabledToggle" AutomationProperties.Name="System stats sampling" Style="{StaticResource SettingsToggle}" Toggled="FeatureSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Follow active monitor" />
                            <ToggleSwitch x:Name="FollowActiveMonitorToggle" AutomationProperties.Name="Follow active monitor" Style="{StaticResource SettingsToggle}" Toggled="FeatureSettingChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SettingsSectionHeader}" Text="Shelf" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Drop staging shelf" />
                            <ToggleSwitch x:Name="ShelfEnabledToggle" AutomationProperties.Name="Drop staging shelf" Style="{StaticResource SettingsToggle}" Toggled="ShelfSettingChanged" />
                        </Grid>
                        <Grid MinHeight="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Memory cap" />
                            <ComboBox
                                x:Name="ShelfCapComboBox"
                                Grid.Column="1"
                                MinWidth="128"
                                AutomationProperties.Name="Shelf memory cap"
                                SelectionChanged="ShelfSettingChanged">
                                <ComboBoxItem Content="4 items" Tag="4" />
                                <ComboBoxItem Content="8 items" Tag="8" />
                                <ComboBoxItem Content="12 items" Tag="12" />
                                <ComboBoxItem Content="24 items" Tag="24" />
                            </ComboBox>
                        </Grid>
                        <TextBlock Style="{StaticResource SettingsDescription}" Text="In-memory only; clears when Winotch exits." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SettingsSectionHeader}" Text="Droplets" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Color picker" />
                            <ToggleSwitch x:Name="ColorPickerEnabledToggle" AutomationProperties.Name="Color picker" Style="{StaticResource SettingsToggle}" Toggled="DropletSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Text scrubber" />
                            <ToggleSwitch x:Name="TextScrubberEnabledToggle" AutomationProperties.Name="Text scrubber" Style="{StaticResource SettingsToggle}" Toggled="DropletSettingChanged" />
                        </Grid>
                        <TextBlock Style="{StaticResource SettingsDescription}" Text="All droplet actions stay on this device." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SettingsSectionHeader}" Text="Toasts" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Media toasts" />
                            <ToggleSwitch x:Name="MediaToastsToggle" AutomationProperties.Name="Media toasts" Style="{StaticResource SettingsToggle}" Toggled="ToastSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Notification toasts" />
                            <ToggleSwitch x:Name="NotificationToastsToggle" AutomationProperties.Name="Notification toasts" Style="{StaticResource SettingsToggle}" Toggled="ToastSettingChanged" />
                        </Grid>
                        <Grid MinHeight="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Notification history" />
                            <Button
                                x:Name="RequestNotificationAccessButton"
                                Grid.Column="1"
                                AutomationProperties.Name="Request notification access"
                                Click="RequestNotificationAccessClick"
                                Content="Request access" />
                        </Grid>
                        <TextBlock
                            x:Name="NotificationAccessStatusText"
                            AutomationProperties.LiveSetting="Polite"
                            Style="{StaticResource SettingsDescription}"
                            Visibility="Collapsed" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Priority alerts" />
                            <ToggleSwitch x:Name="PriorityAlertsToggle" AutomationProperties.Name="Priority alerts" Style="{StaticResource SettingsToggle}" Toggled="ToastSettingChanged" />
                        </Grid>
                        <Grid MinHeight="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Duration scale" />
                            <ComboBox
                                x:Name="ToastDurationComboBox"
                                Grid.Column="1"
                                MinWidth="128"
                                AutomationProperties.Name="Toast duration scale"
                                SelectionChanged="ToastDurationChanged">
                                <ComboBoxItem Content="0.75x" Tag="Short" />
                                <ComboBoxItem Content="1x" Tag="Normal" />
                                <ComboBoxItem Content="1.5x" Tag="Long" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SettingsSectionHeader}" Text="Live Activities" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Activity dots" />
                            <ToggleSwitch x:Name="ActivityDotsEnabledToggle" AutomationProperties.Name="Activity dots" Style="{StaticResource SettingsToggle}" Toggled="LiveActivitySettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Now-playing strip" />
                            <ToggleSwitch x:Name="NowPlayingStripEnabledToggle" AutomationProperties.Name="Now-playing strip" Style="{StaticResource SettingsToggle}" Toggled="LiveActivitySettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Transient timer" />
                            <ToggleSwitch x:Name="TransientTimerEnabledToggle" AutomationProperties.Name="Transient timer" Style="{StaticResource SettingsToggle}" Toggled="LiveActivitySettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Call detection" />
                            <ToggleSwitch x:Name="CallDetectionEnabledToggle" AutomationProperties.Name="Call detection" Style="{StaticResource SettingsToggle}" Toggled="LiveActivitySettingChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SettingsSectionHeader}" Text="Calendar" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Next meeting countdown" />
                            <ToggleSwitch x:Name="CalendarEnabledToggle" AutomationProperties.Name="Next meeting countdown" Style="{StaticResource SettingsToggle}" Toggled="CalendarSettingChanged" />
                        </Grid>
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource SettingsDescription}" Text="ICS subscription URLs" />
                        <TextBox
                            x:Name="CalendarUrlsTextBox"
                            Height="104"
                            AcceptsReturn="True"
                            AutomationProperties.Name="ICS subscription URLs"
                            Style="{StaticResource NotchTextBox}"
                            TextChanged="CalendarUrlsChanged"
                            TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource SettingsDescription}" Text="Refreshes every 5 minutes." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SettingsSectionHeader}" Text="Command Bar" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Global command bar" />
                            <ToggleSwitch x:Name="CommandBarEnabledToggle" AutomationProperties.Name="Global command bar" Style="{StaticResource SettingsToggle}" Toggled="CommandBarSettingChanged" />
                        </Grid>
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource SettingsDescription}" Text="Hotkey" />
                        <TextBox
                            x:Name="CommandBarHotkeyTextBox"
                            AutomationProperties.Name="Command bar hotkey"
                            Style="{StaticResource NotchTextBox}"
                            TextChanged="CommandBarSettingChanged" />
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="App launcher" />
                            <ToggleSwitch x:Name="CommandBarAppsToggle" AutomationProperties.Name="App launcher" Style="{StaticResource SettingsToggle}" Toggled="CommandBarSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Window switcher" />
                            <ToggleSwitch x:Name="CommandBarWindowsToggle" AutomationProperties.Name="Window switcher" Style="{StaticResource SettingsToggle}" Toggled="CommandBarSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Calculator" />
                            <ToggleSwitch x:Name="CommandBarCalculatorToggle" AutomationProperties.Name="Calculator" Style="{StaticResource SettingsToggle}" Toggled="CommandBarSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Unit converter" />
                            <ToggleSwitch x:Name="CommandBarUnitsToggle" AutomationProperties.Name="Unit converter" Style="{StaticResource SettingsToggle}" Toggled="CommandBarSettingChanged" />
                        </Grid>
                        <Grid Style="{StaticResource SettingsRow}">
                            <TextBlock Style="{StaticResource SettingsLabel}" Text="Quick commands" />
                            <ToggleSwitch x:Name="CommandBarQuickCommandsToggle" AutomationProperties.Name="Quick commands" Style="{StaticResource SettingsToggle}" Toggled="CommandBarSettingChanged" />
                        </Grid>
                        <TextBlock Style="{StaticResource SettingsDescription}" Text="All command providers are local. Currency conversion and web lookup are not included." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsCard}" Margin="0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SettingsSectionHeader}" Text="About" />
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Winotch" />
                        <TextBlock x:Name="VersionText" Margin="0,4,0,0" Style="{StaticResource SettingsDescription}" />
                        <Button
                            x:Name="CopyDiagnosticsButton"
                            Margin="0,16,0,0"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="Copy diagnostics"
                            Click="CopyDiagnosticsClick"
                            Content="Copy diagnostics" />
                        <TextBlock
                            x:Name="DiagnosticsStatusText"
                            Margin="0,8,0,0"
                            AutomationProperties.LiveSetting="Polite"
                            Style="{StaticResource SettingsDescription}"
                            Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</local:FluentWindow>
