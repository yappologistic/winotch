<Window x:Class="Winotch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Winotch"
        Title="Winotch Settings"
        Width="520"
        Height="640"
        MinWidth="480"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="False"
        Background="{StaticResource NotchBlack}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource NotchMutedText}" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource NotchText}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid MinHeight="{TemplateBinding MinHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                            <Border x:Name="SwitchTrack"
                                    Grid.Column="1"
                                    Width="52"
                                    Height="28"
                                    CornerRadius="14"
                                    Background="#343434"
                                    Margin="16,0,0,0">
                                <Ellipse x:Name="SwitchThumb"
                                         Width="22"
                                         Height="22"
                                         HorizontalAlignment="Left"
                                         Margin="3"
                                         Fill="{StaticResource NotchText}" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#2FD36B" />
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="27,3,3,3" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource NotchText}" />
            <Setter Property="Background" Value="{StaticResource NotchPanel}" />
            <Setter Property="BorderBrush" Value="#303030" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="120" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource NotchText}" />
            <Setter Property="Background" Value="{StaticResource NotchPanel}" />
            <Setter Property="Padding" Value="10,6" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="Winotch Settings"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Margin="0,0,0,24" />

            <Border Background="{StaticResource NotchPanel}"
                    CornerRadius="8"
                    Padding="18"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="General" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="Use24HourClockToggle"
                              Content="24-hour clock"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="GeneralSettingChanged"
                              Unchecked="GeneralSettingChanged" />
                    <CheckBox x:Name="ShowDateToggle"
                              Content="Show date"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,10,0,0"
                              Checked="GeneralSettingChanged"
                              Unchecked="GeneralSettingChanged" />
                    <CheckBox x:Name="StartWithWindowsToggle"
                              Content="Start with Windows"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,10,0,0"
                              Checked="StartWithWindowsChanged"
                              Unchecked="StartWithWindowsChanged" />
                    <TextBlock x:Name="StartupStatusText"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource NotchPanel}"
                    CornerRadius="8"
                    Padding="18"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Toasts" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="MediaToastsToggle"
                              Content="Media toasts"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="ToastSettingChanged"
                              Unchecked="ToastSettingChanged" />
                    <CheckBox x:Name="NotificationToastsToggle"
                              Content="Notification toasts"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,10,0,0"
                              Checked="ToastSettingChanged"
                              Unchecked="ToastSettingChanged" />
                    <CheckBox x:Name="PriorityAlertsToggle"
                              Content="Priority alerts"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,10,0,0"
                              Checked="ToastSettingChanged"
                              Unchecked="ToastSettingChanged" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Duration scale"
                                   VerticalAlignment="Center"
                                   FontSize="14" />
                        <ComboBox x:Name="ToastDurationComboBox"
                                  Grid.Column="1"
                                  SelectionChanged="ToastDurationChanged">
                            <ComboBoxItem Content="0.75x" Tag="{x:Static local:ToastDurationScale.Short}" />
                            <ComboBoxItem Content="1x" Tag="{x:Static local:ToastDurationScale.Normal}" />
                            <ComboBoxItem Content="1.5x" Tag="{x:Static local:ToastDurationScale.Long}" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource NotchPanel}"
                    CornerRadius="8"
                    Padding="18"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Calendar" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="CalendarEnabledToggle"
                              Content="Next meeting countdown"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="CalendarSettingChanged"
                              Unchecked="CalendarSettingChanged" />
                    <TextBlock Text="ICS subscription URLs"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               Margin="0,14,0,6" />
                    <TextBox x:Name="CalendarUrlsTextBox"
                             Height="86"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="{StaticResource NotchBlack}"
                             Foreground="{StaticResource NotchText}"
                             BorderBrush="#343434"
                             BorderThickness="1"
                             Padding="9,7"
                             CaretBrush="{StaticResource NotchText}"
                             FontFamily="Segoe UI Variable Text, Segoe UI"
                             FontSize="12"
                             TextChanged="CalendarUrlsChanged" />
                    <TextBlock Text="Refreshes every 5 minutes"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource NotchPanel}"
                    CornerRadius="8"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="About" Style="{StaticResource SettingsSectionHeader}" />
                    <TextBlock Text="Winotch"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="VersionText"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
