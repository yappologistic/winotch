<Window x:Class="Winotch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Winotch"
        Title="Winotch Settings"
        Width="560"
        Height="700"
        Icon="Resources/WinotchTray.ico"
        MinWidth="520"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Topmost="False"
        Background="{StaticResource NotchBlack}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="SettingsSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource NotchMutedText}" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource NotchPanel}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource NotchText}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid MinHeight="{TemplateBinding MinHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="0,0,16,0"
                                              RecognizesAccessKey="True" />
                            <Border x:Name="SwitchTrack"
                                    Grid.Column="1"
                                    Width="54"
                                    Height="30"
                                    CornerRadius="15"
                                    Background="{StaticResource NotchStroke}"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    Margin="14,0,0,0">
                                <Ellipse x:Name="SwitchThumb"
                                         Width="24"
                                         Height="24"
                                         HorizontalAlignment="Left"
                                         Margin="2"
                                         Fill="{StaticResource NotchText}"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource NotchAccent}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchThumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="24"
                                                             Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchThumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0"
                                                             Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{StaticResource NotchMutedText}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{StaticResource NotchText}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource NotchText}" />
            <Setter Property="Background" Value="{StaticResource NotchPanel}" />
            <Setter Property="BorderBrush" Value="{StaticResource NotchStroke}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MaxDropDownHeight" Value="180" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ComboChrome"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          ClickMode="Press"
                                          Focusable="False"
                                          Foreground="{TemplateBinding Foreground}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Padding="{TemplateBinding Padding}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  HorizontalAlignment="Left"
                                                                  Margin="0,0,22,0"
                                                                  VerticalAlignment="Center" />
                                                <TextBlock Style="{StaticResource IconText}"
                                                           Text="&#xE70D;"
                                                           FontSize="10"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{StaticResource NotchPanel}"
                                        BorderBrush="{StaticResource NotchStroke}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="3">
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboChrome" Property="Background" Value="{StaticResource NotchPanelHover}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboChrome" Property="Background" Value="{StaticResource NotchPanelPressed}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboChrome" Property="BorderBrush" Value="{StaticResource NotchMutedText}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource NotchText}" />
            <Setter Property="Background" Value="{StaticResource NotchPanel}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource NotchPanelHover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource NotchPanelPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">
        <StackPanel Margin="32">
            <TextBlock Text="Winotch Settings"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Margin="0,0,0,26" />

            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="General" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="Use24HourClockToggle"
                              Content="24-hour clock"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="GeneralSettingChanged"
                              Unchecked="GeneralSettingChanged" />
                    <CheckBox x:Name="ShowDateToggle"
                              Content="Show date"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="GeneralSettingChanged"
                              Unchecked="GeneralSettingChanged" />
                    <CheckBox x:Name="StartWithWindowsToggle"
                              Content="Start with Windows"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="StartWithWindowsChanged"
                              Unchecked="StartWithWindowsChanged" />
                    <TextBlock x:Name="StartupStatusText"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="Features" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="ClipboardHistoryEnabledToggle"
                              Content="Clipboard capture"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="FeatureSettingChanged"
                              Unchecked="FeatureSettingChanged" />
                    <CheckBox x:Name="ShowAppMixerToggle"
                              Content="Per-app audio mixer"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="FeatureSettingChanged"
                              Unchecked="FeatureSettingChanged" />
                    <CheckBox x:Name="SystemStatsEnabledToggle"
                              Content="System stats sampling"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="FeatureSettingChanged"
                              Unchecked="FeatureSettingChanged" />
                    <CheckBox x:Name="FollowActiveMonitorToggle"
                              Content="Follow active monitor"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="FeatureSettingChanged"
                              Unchecked="FeatureSettingChanged" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="Shelf" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="ShelfEnabledToggle"
                              Content="Drop staging shelf"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="ShelfSettingChanged"
                              Unchecked="ShelfSettingChanged" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Memory cap"
                                   VerticalAlignment="Center"
                                   FontSize="14" />
                        <ComboBox x:Name="ShelfCapComboBox"
                                  Grid.Column="1"
                                  AutomationProperties.Name="Shelf memory cap"
                                  SelectionChanged="ShelfSettingChanged">
                            <ComboBoxItem Content="4 items" Tag="4" />
                            <ComboBoxItem Content="8 items" Tag="8" />
                            <ComboBoxItem Content="12 items" Tag="12" />
                            <ComboBoxItem Content="24 items" Tag="24" />
                        </ComboBox>
                    </Grid>
                    <TextBlock Text="In-memory only; clears when Winotch exits."
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="Droplets" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="ColorPickerEnabledToggle"
                              Content="Color picker"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="DropletSettingChanged"
                              Unchecked="DropletSettingChanged" />
                    <CheckBox x:Name="QrStudioEnabledToggle"
                              Content="QR studio"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="DropletSettingChanged"
                              Unchecked="DropletSettingChanged" />
                    <CheckBox x:Name="TextScrubberEnabledToggle"
                              Content="Text scrubber"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="DropletSettingChanged"
                              Unchecked="DropletSettingChanged" />
                    <TextBlock Text="All droplet actions are local; no network calls or packages."
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="Toasts" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="MediaToastsToggle"
                              Content="Media toasts"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="ToastSettingChanged"
                              Unchecked="ToastSettingChanged" />
                    <CheckBox x:Name="NotificationToastsToggle"
                              Content="Notification toasts"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="ToastSettingChanged"
                              Unchecked="ToastSettingChanged" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Notification history"
                                   VerticalAlignment="Center"
                                   FontSize="14" />
                        <Button x:Name="RequestNotificationAccessButton"
                                Grid.Column="1"
                                Content="Request access"
                                AutomationProperties.Name="Request notification access"
                                Click="RequestNotificationAccessClick" />
                    </Grid>
                    <TextBlock x:Name="NotificationAccessStatusText"
                               Text=""
                               Visibility="Collapsed"
                               AutomationProperties.LiveSetting="Polite"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                    <CheckBox x:Name="PriorityAlertsToggle"
                              Content="Priority alerts"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="ToastSettingChanged"
                              Unchecked="ToastSettingChanged" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Duration scale"
                                   VerticalAlignment="Center"
                                   FontSize="14" />
                        <ComboBox x:Name="ToastDurationComboBox"
                                  Grid.Column="1"
                                  AutomationProperties.Name="Toast duration scale"
                                  SelectionChanged="ToastDurationChanged">
                            <ComboBoxItem Content="0.75x" Tag="{x:Static local:ToastDurationScale.Short}" />
                            <ComboBoxItem Content="1x" Tag="{x:Static local:ToastDurationScale.Normal}" />
                            <ComboBoxItem Content="1.5x" Tag="{x:Static local:ToastDurationScale.Long}" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="Live Activities" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="ActivityDotsEnabledToggle"
                              Content="Activity dots"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="LiveActivitySettingChanged"
                              Unchecked="LiveActivitySettingChanged" />
                    <CheckBox x:Name="NowPlayingStripEnabledToggle"
                              Content="Now-playing strip"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="LiveActivitySettingChanged"
                              Unchecked="LiveActivitySettingChanged" />
                    <CheckBox x:Name="TransientTimerEnabledToggle"
                              Content="Transient timer"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="LiveActivitySettingChanged"
                              Unchecked="LiveActivitySettingChanged" />
                    <CheckBox x:Name="CallDetectionEnabledToggle"
                              Content="Call detection"
                              Style="{StaticResource ToggleSwitch}"
                              Margin="0,12,0,0"
                              Checked="LiveActivitySettingChanged"
                              Unchecked="LiveActivitySettingChanged" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="Calendar" Style="{StaticResource SettingsSectionHeader}" />
                    <CheckBox x:Name="CalendarEnabledToggle"
                              Content="Next meeting countdown"
                              Style="{StaticResource ToggleSwitch}"
                              Checked="CalendarSettingChanged"
                              Unchecked="CalendarSettingChanged" />
                    <TextBlock Text="ICS subscription URLs"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               Margin="0,16,0,7" />
                    <TextBox x:Name="CalendarUrlsTextBox"
                             Height="96"
                             AcceptsReturn="True"
                             AutomationProperties.Name="ICS subscription URLs"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="{StaticResource NotchBlack}"
                             Style="{StaticResource NotchTextBox}"
                             Padding="9,7"
                             FontSize="12"
                             TextChanged="CalendarUrlsChanged" />
                    <TextBlock Text="Refreshes every 5 minutes"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsCard}"
                    Margin="0">
                <StackPanel>
                    <TextBlock Text="About" Style="{StaticResource SettingsSectionHeader}" />
                    <TextBlock Text="Winotch"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="VersionText"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               Margin="0,4,0,0" />
                    <Button x:Name="CopyDiagnosticsButton"
                            Content="Copy diagnostics"
                            AutomationProperties.Name="Copy diagnostics"
                            Click="CopyDiagnosticsClick"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0" />
                    <TextBlock x:Name="DiagnosticsStatusText"
                               Text=""
                               Visibility="Collapsed"
                               AutomationProperties.LiveSetting="Polite"
                               Foreground="{StaticResource NotchMutedText}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
