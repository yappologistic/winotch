<Window x:Class="Winotch.TextScrubberDroplet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Winotch"
        Title="Text scrubber"
        Width="430"
        Height="356"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">
    <Border x:Name="FlyoutChrome" Padding="10" CornerRadius="24" Background="{StaticResource NotchBlack}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" RenderTransformOrigin="0.5,0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="FlyoutScale" ScaleX="0.96" ScaleY="0.96" />
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="86" />
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="38" />
            </Grid.RowDefinitions>
            <Grid Margin="2,0,2,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8D2;" FontSize="15" Margin="0,0,8,0" />
                    <TextBlock Text="Text" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource MediaIconButton}" Width="28" Height="28" Margin="0" ToolTip="Close" AutomationProperties.Name="Close text scrubber" Click="CloseButton_Click">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE711;" FontSize="10" />
                </Button>
            </Grid>
            <TextBox x:Name="InputBox" Grid.Row="1" Style="{StaticResource NotchTextBox}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="12" TextChanged="InputBox_TextChanged" />
            <Grid Grid.Row="2" Margin="0,8,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="TrimToggle" Content="Trim" IsChecked="True" Checked="OptionChanged" Unchecked="OptionChanged" />
                <CheckBox x:Name="LineBreakToggle" Grid.Column="1" Content="No breaks" Margin="14,0,14,0" Checked="OptionChanged" Unchecked="OptionChanged" />
                <ComboBox x:Name="CaseComboBox" Grid.Column="2" SelectionChanged="OptionChanged">
                    <ComboBoxItem Content="Case: Preserve" Tag="{x:Static local:TextScrubCase.Preserve}" IsSelected="True" />
                    <ComboBoxItem Content="Case: Upper" Tag="{x:Static local:TextScrubCase.Upper}" />
                    <ComboBoxItem Content="Case: Lower" Tag="{x:Static local:TextScrubCase.Lower}" />
                    <ComboBoxItem Content="Case: Title" Tag="{x:Static local:TextScrubCase.Title}" />
                    <ComboBoxItem Content="Case: Sentence" Tag="{x:Static local:TextScrubCase.Sentence}" />
                </ComboBox>
            </Grid>
            <TextBox x:Name="OutputBox" Grid.Row="3" Style="{StaticResource NotchTextBox}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontSize="12" />
            <DockPanel Grid.Row="4" Margin="0,10,0,0">
                <TextBlock x:Name="CountText" DockPanel.Dock="Left" FontSize="12" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Paste" Padding="11,6" Margin="0,0,8,0" Click="PasteButton_Click" />
                    <Button Content="Copy" Padding="11,6" Click="CopyButton_Click" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
