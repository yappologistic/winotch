<UserControl x:Class="Winotch.LiveStripPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid Height="44">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel x:Name="DotsPanel"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0" />

        <Border x:Name="ArtworkBadge"
                Grid.Column="1"
                Width="34"
                Height="34"
                CornerRadius="8"
                Background="{StaticResource NotchPanel}"
                ClipToBounds="True"
                VerticalAlignment="Center"
                Margin="0,0,10,0">
            <Grid>
                <Image x:Name="ArtworkImage" Stretch="UniformToFill" Visibility="Collapsed" />
                <TextBlock x:Name="ArtworkFallback"
                           Style="{StaticResource IconText}"
                           Text="&#xE121;"
                           FontSize="14"
                           Foreground="{StaticResource NotchMutedText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Column="2" VerticalAlignment="Center" MinWidth="170">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="TimeText"
                           DockPanel.Dock="Right"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource NotchMutedText}"
                           Margin="10,0,0,0"
                           Typography.NumeralAlignment="Tabular" />
                <TextBlock x:Name="TitleText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
            <TextBlock x:Name="SubtitleText"
                       Grid.Row="1"
                       FontSize="11"
                       Foreground="{StaticResource NotchMutedText}"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,1,0,0" />
            <ProgressBar x:Name="ActivityProgress"
                         Grid.Row="2"
                         Style="{StaticResource ModernProgressBar}"
                         Height="3"
                         Maximum="100"
                         Margin="0,5,0,0" />
        </Grid>

        <Grid x:Name="TimerRing"
              Grid.Column="3"
              Width="28"
              Height="28"
              Margin="12,0,0,0"
              VerticalAlignment="Center">
            <Ellipse Stroke="{StaticResource NotchStroke}" StrokeThickness="3" />
            <Path x:Name="TimerRingPath"
                  Stroke="{StaticResource NotchText}"
                  StrokeThickness="3"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round" />
        </Grid>

        <StackPanel x:Name="TimerActions"
                    Grid.Column="4"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="10,0,0,0">
            <Button x:Name="PauseResumeButton"
                    Style="{StaticResource MediaIconButton}"
                    Width="28"
                    Height="28"
                    Margin="0,0,6,0"
                    Padding="0"
                    ToolTip="Pause or resume timer"
                    AutomationProperties.Name="Pause or resume live timer"
                    Click="PauseResumeButton_Click">
                <TextBlock x:Name="PauseResumeIcon"
                           Style="{StaticResource IconText}"
                           Text="&#xE769;"
                           FontSize="12" />
            </Button>
            <Button Style="{StaticResource MediaIconButton}"
                    Width="28"
                    Height="28"
                    Margin="0"
                    Padding="0"
                    ToolTip="Cancel timer"
                    AutomationProperties.Name="Cancel live timer"
                    Click="CancelButton_Click">
                <TextBlock Style="{StaticResource IconText}" Text="&#xE711;" FontSize="10" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
