<UserControl
    x:Class="Winotch.LiveStripPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    UseLayoutRounding="True">
    <Grid Height="44">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel
            x:Name="DotsPanel"
            Margin="0,0,10,0"
            VerticalAlignment="Center"
            Orientation="Horizontal" />

        <Border
            x:Name="ArtworkBadge"
            Grid.Column="1"
            Width="34"
            Height="34"
            Margin="0,0,10,0"
            VerticalAlignment="Center"
            Background="{StaticResource NotchPanel}"
            CornerRadius="8">
            <Grid>
                <TextBlock
                    x:Name="ArtworkFallback"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="{StaticResource NotchMutedText}"
                    Style="{StaticResource IconText}"
                    Text="&#xE121;" />
                <Image
                    x:Name="ArtworkImage"
                    Stretch="UniformToFill"
                    Visibility="Collapsed" />
            </Grid>
        </Border>

        <Grid Grid.Column="2" MinWidth="170" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="TitleText"
                    FontSize="13"
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    x:Name="TimeText"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource NotchMutedText}" />
            </Grid>

            <TextBlock
                x:Name="SubtitleText"
                Grid.Row="1"
                Margin="0,1,0,0"
                FontSize="11"
                Foreground="{StaticResource NotchMutedText}"
                TextTrimming="CharacterEllipsis" />
            <ProgressBar
                x:Name="ActivityProgress"
                Grid.Row="2"
                Height="3"
                Margin="0,5,0,0"
                Maximum="100"
                Style="{StaticResource ModernProgressBar}" />
        </Grid>
    </Grid>
</UserControl>
