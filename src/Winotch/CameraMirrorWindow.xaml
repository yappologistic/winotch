<Window x:Class="Winotch.CameraMirrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Camera mirror"
        Width="380"
        Height="292"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="CameraMirrorToggleButton" TargetType="{x:Type ToggleButton}">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="Foreground" Value="{StaticResource NotchText}" />
            <Setter Property="Background" Value="{StaticResource NotchPanel}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ToggleChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="ToggleChrome" Property="Background" Value="{StaticResource NotchPanelPressed}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleChrome" Property="Background" Value="{StaticResource NotchPanelHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ToggleChrome" Property="Background" Value="{StaticResource NotchStroke}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ToggleChrome" Property="BorderBrush" Value="{StaticResource NotchMutedText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="FlyoutChrome"
            Margin="0"
            Padding="10"
            CornerRadius="24"
            Background="{StaticResource NotchBlack}"
            BorderBrush="{StaticResource NotchStroke}"
            BorderThickness="1"
            RenderTransformOrigin="0.5,0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="FlyoutScale" ScaleX="0.96" ScaleY="0.96" />
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="2,0,2,8">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE722;" FontSize="15" Margin="0,0,8,0" />
                    <TextBlock Text="Mirror" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <ToggleButton x:Name="MirrorToggleButton"
                                  Style="{StaticResource CameraMirrorToggleButton}"
                                  IsChecked="True"
                                  Margin="0,0,8,0"
                                  ToolTip="Show unmirrored preview"
                                  AutomationProperties.Name="Mirror camera preview"
                                  Click="MirrorToggleButton_Click">
                        <TextBlock x:Name="MirrorToggleText" Text="Mirror" FontSize="11" />
                    </ToggleButton>
                    <Button Style="{StaticResource MediaIconButton}"
                            Width="28"
                            Height="28"
                            Margin="0"
                            ToolTip="Close"
                            AutomationProperties.Name="Close camera mirror"
                            Click="CloseButton_Click">
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE711;" FontSize="10" />
                    </Button>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    CornerRadius="18"
                    Background="{StaticResource NotchPanel}"
                    ClipToBounds="True"
                    SnapsToDevicePixels="True">
                <Grid x:Name="PreviewViewport"
                      ClipToBounds="True"
                      SizeChanged="PreviewViewport_SizeChanged">
                    <Canvas Background="Transparent"
                            ClipToBounds="True">
                        <Image x:Name="PreviewImage"
                               Stretch="Fill"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="Fant"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <ScaleTransform x:Name="PreviewMirrorTransform" ScaleX="-1" ScaleY="1" />
                            </Image.RenderTransform>
                        </Image>
                    </Canvas>
                    <TextBlock x:Name="MirrorMessageText"
                               Text="Opening camera"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource NotchMutedText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
