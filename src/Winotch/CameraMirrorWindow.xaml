<local:FluentWindow
    x:Class="Winotch.CameraMirrorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winotch"
    Title="Camera mirror"
    Width="380"
    Height="292"
    Topmost="True"
    ShowInTaskbar="False"
    AttachToTopEdge="False"
    BottomCornerRadius="24"
    Loaded="Window_Loaded"
    Activated="Window_Activated"
    Closed="Window_Closed">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="EscapeKeyboardAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>

        <!-- The rounded flyout material is rendered by the system compositor. -->
        <SystemBackdropElement CornerRadius="24">
            <SystemBackdropElement.SystemBackdrop>
                <DesktopAcrylicBackdrop />
            </SystemBackdropElement.SystemBackdrop>
        </SystemBackdropElement>

        <Border
            x:Name="FlyoutChrome"
            Padding="10"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid
                    Margin="2,0,2,8"
                    Background="Transparent"
                    PointerPressed="HeaderDragArea_PointerPressed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock
                            Margin="0,0,8,0"
                            FontFamily="{StaticResource WinotchIconFont}"
                            FontSize="15"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Text="&#xE722;" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Text="Mirror" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="8">
                        <ToggleButton
                            x:Name="MirrorToggleButton"
                            MinWidth="68"
                            Padding="10,5"
                            AutomationProperties.Name="Mirror camera preview"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Click="MirrorToggleButton_Click"
                            CornerRadius="9"
                            IsChecked="True"
                            ToolTipService.ToolTip="Show unmirrored preview">
                            <TextBlock x:Name="MirrorToggleText" FontSize="11" Text="Mirror" />
                        </ToggleButton>
                        <Button
                            Width="28"
                            Height="28"
                            Margin="0"
                            Padding="0"
                            AutomationProperties.Name="Close camera mirror"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="CloseButton_Click"
                            CornerRadius="14"
                            ToolTipService.ToolTip="Close">
                            <TextBlock
                                FontFamily="{StaticResource WinotchIconFont}"
                                FontSize="10"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                Text="&#xE711;" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource LayerFillColorAltBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                    <Grid
                        x:Name="PreviewViewport"
                        SizeChanged="PreviewViewport_SizeChanged">
                        <Canvas Background="Transparent">
                            <Image
                                x:Name="PreviewImage"
                                RenderTransformOrigin="0.5,0.5"
                                Stretch="Fill">
                                <Image.RenderTransform>
                                    <ScaleTransform x:Name="PreviewMirrorTransform" ScaleX="-1" ScaleY="1" />
                                </Image.RenderTransform>
                            </Image>
                        </Canvas>
                        <TextBlock
                            x:Name="MirrorMessageText"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Opening camera" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</local:FluentWindow>
