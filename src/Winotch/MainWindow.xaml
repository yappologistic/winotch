<Window x:Class="Winotch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Winotch"
        mc:Ignorable="d"
        Title="Winotch"
        Width="680"
        Height="40"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        AllowDrop="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop">
    <Grid Background="Transparent">
        <Border x:Name="NotchShell"
                Width="220"
                Height="40"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Background="{StaticResource NotchBlack}"
                CornerRadius="0,0,20,20"
                Padding="10,4,10,6"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.16" Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="HeaderRow" Height="28" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="ClockGroup" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border x:Name="LogoBadge" Width="28" Height="28" CornerRadius="14" Background="{StaticResource NotchPanel}" Margin="0,0,10,0">
                            <Grid>
                                <Ellipse x:Name="LogoAccountPicture" Visibility="Collapsed" />
                                <TextBlock x:Name="LogoFallbackText" Text="W" FontWeight="Bold" FontSize="14" LineHeight="18" LineStackingStrategy="BlockLineHeight" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Border x:Name="ShelfMiniIndicator"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{StaticResource NotchPanelHover}"
                                        BorderBrush="{StaticResource NotchBlack}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,-4,-4"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="ShelfMiniCountText"
                                               FontSize="8"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                        <StackPanel>
                            <TextBlock x:Name="TimeText" FontSize="17" FontWeight="SemiBold" LineHeight="24" LineStackingStrategy="BlockLineHeight" MinWidth="82" />
                            <TextBlock x:Name="DateText" Foreground="{StaticResource NotchMutedText}" FontSize="12" LineHeight="15" Margin="0,1,0,0" />
                        </StackPanel>
                        <StackPanel x:Name="FocusLiveActivity" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed" Margin="12,0,0,0">
                            <Grid Width="26" Height="3" VerticalAlignment="Center" Margin="0,0,7,0" ClipToBounds="True">
                                <Border Background="{StaticResource NotchStroke}" CornerRadius="2" />
                                <Border x:Name="FocusLiveProgressFill" Width="0" HorizontalAlignment="Left" Background="{StaticResource NotchText}" CornerRadius="2" />
                            </Grid>
                            <TextBlock x:Name="FocusLiveRemainingText"
                                       Width="42"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextAlignment="Right"
                                       Typography.NumeralAlignment="Tabular" />
                        </StackPanel>
                        <StackPanel x:Name="CalendarLiveActivity" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed" Margin="10,0,0,0">
                            <Border CornerRadius="13" Background="{StaticResource NotchPanel}" Padding="8,4">
                                <TextBlock x:Name="CalendarLiveText"
                                           Width="90"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="StatusGroup" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE701;" Margin="0,0,6,0" />
                                <TextBlock x:Name="WifiText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" Margin="0,0,6,0" />
                                <TextBlock x:Name="VolumeText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="MicPillIndicator" CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="MicPillGlyph" Style="{StaticResource IconText}" Text="&#xE720;" Margin="0,0,6,0" />
                                <TextBlock x:Name="MicPillText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="26" Height="14" Margin="0,1,7,0">
                                    <Border Width="22"
                                            Height="12"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            BorderBrush="{StaticResource NotchText}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="2">
                                        <Grid ClipToBounds="True">
                                            <Border x:Name="BatteryFill" Width="16" HorizontalAlignment="Left" CornerRadius="1.5" />
                                        </Grid>
                                    </Border>
                                    <Border Width="3" Height="6" HorizontalAlignment="Right" VerticalAlignment="Center" Background="{StaticResource NotchText}" CornerRadius="0,1,1,0" />
                                </Grid>
                                <TextBlock x:Name="BatteryText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xEA8F;" Margin="0,0,6,0" />
                                <TextBlock x:Name="NotificationCountText" FontSize="12" FontWeight="SemiBold" Text="0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="DetailPanel" Grid.Row="1" Opacity="0" Margin="0,10,0,0" ClipToBounds="True">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="380" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                    <StackPanel Margin="2,0,22,0">
                        <TextBlock Text="System" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                        <TextBlock x:Name="LargeTimeText" FontSize="38" FontWeight="Light" Margin="0,4,0,0" />
                        <TextBlock x:Name="LargeDateText" FontSize="14" Foreground="{StaticResource NotchMutedText}" />
                        <ProgressBar x:Name="BatteryBar" Style="{StaticResource ModernProgressBar}" Margin="0,16,0,8" Maximum="100" />
                        <TextBlock x:Name="BatteryDetailText" FontSize="12" Foreground="{StaticResource NotchMutedText}" />
                        <StackPanel x:Name="SystemStatsSection" Margin="0,16,0,0" Visibility="Collapsed" SnapsToDevicePixels="True">
                            <TextBlock Text="Stats" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                            <Grid x:Name="StatsCpuRow" Height="23" Margin="0,7,0,0" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="126" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CPU" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                                <TextBlock x:Name="StatsCpuValueText" Grid.Column="1" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Typography.NumeralAlignment="Tabular" />
                                <local:SparklineControl x:Name="StatsCpuSparkline" Grid.Column="2" Height="18" Stroke="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                            </Grid>
                            <Grid x:Name="StatsRamRow" Height="23" Margin="0,4,0,0" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="126" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="RAM" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                                <TextBlock x:Name="StatsRamValueText" Grid.Column="1" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Typography.NumeralAlignment="Tabular" />
                                <local:SparklineControl x:Name="StatsRamSparkline" Grid.Column="2" Height="18" Stroke="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                            </Grid>
                            <Grid x:Name="StatsNetRow" Height="23" Margin="0,4,0,0" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="148" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Net" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                                <TextBlock x:Name="StatsNetValueText" Grid.Column="1" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Typography.NumeralAlignment="Tabular" />
                                <local:SparklineControl x:Name="StatsNetSparkline" Grid.Column="2" Height="18" Stroke="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="AgendaPanel" Margin="0,18,0,0">
                            <TextBlock Text="Agenda" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                            <TextBlock x:Name="AgendaUpdatedText" FontSize="11" Foreground="{StaticResource NotchMutedText}" Margin="0,3,0,7" />
                            <TextBlock x:Name="AgendaEmptyText"
                                       Text="No meetings in the next 24h"
                                       FontSize="12"
                                       Foreground="{StaticResource NotchMutedText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,2" />
                            <ItemsControl x:Name="AgendaList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:CalendarAgendaRow}">
                                        <Grid Height="32" Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="58" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TimeText}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource NotchMutedText}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       ToolTip="{Binding Title}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="6,0,8,0" />
                                            <Button x:Name="AgendaJoinButton"
                                                    Grid.Column="2"
                                                    Padding="9,5"
                                                    Tag="{Binding JoinUrl}"
                                                    ToolTip="Join meeting"
                                                    AutomationProperties.Name="Join meeting"
                                                    Click="AgendaJoin_Click">
                                                <TextBlock Text="Join" FontSize="11" />
                                            </Button>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding HasJoin}" Value="False">
                                                <Setter TargetName="AgendaJoinButton" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <local:ClipboardHistoryPanel x:Name="ClipboardPanel" Margin="0,18,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,0,0" ClipToBounds="True">
                        <Grid x:Name="MediaPanel" Visibility="Collapsed" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" CornerRadius="9" Background="{StaticResource NotchPanel}" ClipToBounds="True">
                                <Grid>
                                    <Image x:Name="MediaArtworkImage" Stretch="UniformToFill" Visibility="Collapsed" />
                                    <TextBlock x:Name="MediaArtworkFallback"
                                               Text="Audio"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource NotchMutedText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="MediaTitleText" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="MediaArtistText" FontSize="12" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" Margin="0,1,0,7" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="MediaPreviousButton" Style="{StaticResource MediaIconButton}" ToolTip="Previous" AutomationProperties.Name="Previous track" Click="MediaPrevious_Click">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE100;" FontSize="14" />
                                    </Button>
                                    <Button x:Name="MediaPlayPauseButton" Style="{StaticResource MediaIconButton}" ToolTip="Play or pause" AutomationProperties.Name="Play or pause media" Click="MediaPlayPause_Click">
                                        <TextBlock x:Name="MediaPlayPauseIcon" Style="{StaticResource IconText}" Text="&#xE768;" FontSize="14" />
                                    </Button>
                                    <Button x:Name="MediaNextButton" Style="{StaticResource MediaIconButton}" ToolTip="Next" AutomationProperties.Name="Next track" Click="MediaNext_Click">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE101;" FontSize="14" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Notifications" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                        <TextBlock x:Name="NotificationStateText" FontSize="12" Foreground="{StaticResource NotchMutedText}" Margin="0,4,0,8" />
                        <ListBox x:Name="NotificationList"
                                 Height="110"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{StaticResource NotchText}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ItemContainerStyle="{StaticResource NotchListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontSize="12"
                                               LineHeight="17"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="Focus" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                            <StackPanel x:Name="FocusSetupPanel" Margin="0,7,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="25/5" Padding="9,5" Margin="0,0,6,0" Click="FocusShortPreset_Click" />
                                    <Button Content="50/10" Padding="9,5" Margin="0,0,8,0" Click="FocusLongPreset_Click" />
                                    <TextBox x:Name="FocusCustomMinutesBox"
                                             Width="48"
                                             Height="28"
                                             Padding="5,3"
                                             Style="{StaticResource NotchTextBox}"
                                             TextAlignment="Center"
                                             ToolTip="Custom focus minutes"
                                             Typography.NumeralAlignment="Tabular" />
                                </StackPanel>
                                <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                    <CheckBox x:Name="FocusAutoCycleCheckBox"
                                              Content="Auto-cycle"
                                              Foreground="{StaticResource NotchMutedText}"
                                              FontFamily="Segoe UI Variable Text, Segoe UI"
                                              FontSize="11"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0" />
                                    <Button Content="Start" Padding="12,5" Click="FocusStart_Click" />
                                </DockPanel>
                                <TextBlock x:Name="FocusValidationText" FontSize="11" Foreground="{StaticResource NotchDanger}" Visibility="Collapsed" Margin="0,5,0,0" />
                            </StackPanel>
                            <StackPanel x:Name="FocusRunningPanel" Visibility="Collapsed" Margin="0,7,0,0">
                                <DockPanel LastChildFill="True">
                                    <TextBlock x:Name="FocusPhaseText" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                    <TextBlock x:Name="FocusRemainingText"
                                               DockPanel.Dock="Right"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               TextAlignment="Right"
                                               Typography.NumeralAlignment="Tabular" />
                                </DockPanel>
                                <ProgressBar x:Name="FocusProgressBar" Style="{StaticResource ModernProgressBar}" Height="4" Margin="0,6,0,8" Maximum="100" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="FocusPauseResumeButton" Content="Pause" Padding="9,5" Margin="0,0,6,0" Click="FocusPauseResume_Click" />
                                    <Button Content="Skip" Padding="9,5" Margin="0,0,6,0" Click="FocusSkip_Click" />
                                    <Button Content="Stop" Padding="9,5" Click="FocusStop_Click" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Column="1" Margin="0,0,22,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Controls" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                                <Button DockPanel.Dock="Right"
                                        Style="{StaticResource MediaIconButton}"
                                        Width="28"
                                        Height="28"
                                        Margin="0"
                                        ToolTip="Camera mirror"
                                        AutomationProperties.Name="Open camera mirror"
                                        Click="CameraMirror_Click">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE722;" FontSize="13" />
                                </Button>
                            </DockPanel>

                            <ItemsControl x:Name="OutputDeviceList" Margin="0,7,0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Padding="8,5" Margin="0,0,0,5" Click="OutputDevice_Click" ToolTip="{Binding Name}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="18" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" FontSize="13" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="&#xE73E;" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource IconText}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDefault}" Value="False">
                                                                    <Setter Property="Visibility" Value="Hidden" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="54" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" />
                                <TextBlock Grid.Column="1" Text="Master" FontSize="12" VerticalAlignment="Center" />
                                <Slider x:Name="VolumeSlider" Grid.Column="2" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="100" ValueChanged="VolumeSlider_ValueChanged" />
                            </Grid>

                            <StackPanel x:Name="AudioSessionMixerSection" Margin="0,0,0,10">
                                <TextBlock Text="Apps" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                <TextBlock x:Name="NoAudioSessionsText" Text="No active audio sessions" FontSize="12" Foreground="{StaticResource NotchMutedText}" Margin="0,5,0,6" />
                                <ScrollViewer x:Name="AudioSessionScroll" Height="132" Margin="0,4,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="AudioSessionList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="31" Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24" />
                                                        <ColumnDefinition Width="72" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="32" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Width="22" Height="22" VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" FontSize="12" HorizontalAlignment="Center" />
                                                        <Image Source="{Binding Icon}" Width="22" Height="22" Stretch="UniformToFill">
                                                            <Image.Style>
                                                                <Style TargetType="Image">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>
                                                    </Grid>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" ToolTip="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    <Slider Grid.Column="2" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="100" Value="{Binding Volume}" ValueChanged="AudioSessionVolumeSlider_ValueChanged" />
                                                    <Button Grid.Column="3" Style="{StaticResource MediaIconButton}" Margin="6,0,0,0" ToolTip="Mute app" Click="AudioSessionMute_Click">
                                                        <TextBlock FontSize="12">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource IconText}">
                                                                    <Setter Property="Text" Value="&#xE767;" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                                                            <Setter Property="Text" Value="&#xE74F;" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="MicRowGlyph" Style="{StaticResource IconText}" Text="&#xE720;" />
                                <TextBlock x:Name="MicRowStateText" Grid.Column="1" FontSize="12" VerticalAlignment="Center" />
                                <Button x:Name="MicMuteButton" Grid.Column="2" Padding="9,5" Click="MicMute_Click">
                                    <TextBlock x:Name="MicMuteButtonText" FontSize="11" />
                                </Button>
                            </Grid>

                            <StackPanel x:Name="BrightnessBlock" Margin="0,0,0,12" Visibility="Collapsed">
                                <TextBlock Text="Brightness" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                <ItemsControl x:Name="BrightnessList" Margin="0,5,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="31" Margin="0,0,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24" />
                                                    <ColumnDefinition Width="72" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource IconText}" Text="&#xE706;" FontSize="13" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" ToolTip="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                <Slider Grid.Column="2" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="100" Value="{Binding Percent}" ValueChanged="BrightnessSlider_ValueChanged" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <TextBlock Text="Wi-Fi" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                            <TextBlock x:Name="WifiStateText" FontSize="12" Foreground="{StaticResource NotchText}" Margin="0,5,0,6" TextWrapping="Wrap" />
                            <ListBox x:Name="WifiList"
                                     Height="42"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{StaticResource NotchText}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ItemContainerStyle="{StaticResource NotchListBoxItem}" />
                            <Button x:Name="ConnectWifiButton" Content="Connect" HorizontalAlignment="Left" Margin="0,8,0,0" Click="ConnectWifi_Click" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="ShelfSection"
                            Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Margin="2,10,2,0"
                            Padding="10,7"
                            CornerRadius="12"
                            Background="{StaticResource NotchPanel}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="48" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Shelf" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                    <Border CornerRadius="8" Background="{StaticResource NotchPanelHover}" Padding="6,1" Margin="7,0,0,0">
                                        <TextBlock x:Name="ShelfSectionCountText" FontSize="10" FontWeight="SemiBold" />
                                    </Border>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="ShelfDragAllButton"
                                            Style="{StaticResource MediaIconButton}"
                                            Width="24"
                                            Height="24"
                                            Margin="0,0,4,0"
                                            ToolTip="Drag all shelf items"
                                            AutomationProperties.Name="Drag all shelf items"
                                            PreviewMouseLeftButtonDown="ShelfDragAll_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="ShelfDragSource_PreviewMouseMove">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE8E5;" FontSize="12" />
                                    </Button>
                                    <Button x:Name="ShelfClearButton" Padding="8,4" Margin="0" Click="ShelfClear_Click" AutomationProperties.Name="Clear shelf">
                                        <TextBlock Text="Clear" FontSize="11" />
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                            <Grid Grid.Row="1" Margin="0,7,0,0">
                                <TextBlock x:Name="ShelfEmptyText"
                                           Text="Shelf empty"
                                           FontSize="12"
                                           Foreground="{StaticResource NotchMutedText}"
                                           VerticalAlignment="Center" />
                                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="ShelfItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:ShelfTileViewModel}">
                                                <Border x:Name="TileChrome"
                                                        Width="104"
                                                        Height="42"
                                                        Margin="0,0,8,0"
                                                        Padding="7"
                                                        CornerRadius="9"
                                                        Background="{StaticResource NotchPanelRaised}"
                                                        ToolTip="{Binding FullPath}"
                                                        PreviewMouseLeftButtonDown="ShelfItem_PreviewMouseLeftButtonDown"
                                                        PreviewMouseMove="ShelfDragSource_PreviewMouseMove">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="24" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="20" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid Width="22" Height="22" VerticalAlignment="Center">
                                                            <Image Source="{Binding Icon}" Stretch="Uniform" />
                                                            <Border x:Name="ShelfIconFallback" CornerRadius="5" Background="{StaticResource NotchPanelPressed}" Visibility="Collapsed">
                                                                <TextBlock Style="{StaticResource IconText}" Text="&#xE160;" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding DisplayName}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Margin="6,0,2,0"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <Button x:Name="RemoveShelfItemButton"
                                                                Grid.Column="2"
                                                                Width="18"
                                                                Height="18"
                                                                Padding="0"
                                                                Background="{StaticResource NotchPanelPressed}"
                                                                Opacity="0"
                                                                Tag="{Binding FullPath}"
                                                                ToolTip="Remove"
                                                                AutomationProperties.Name="Remove shelf item"
                                                                Click="ShelfRemove_Click">
                                                            <TextBlock Style="{StaticResource IconText}" Text="&#xE711;" FontSize="9" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                        <Setter TargetName="ShelfIconFallback" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Exists}" Value="False">
                                                        <Setter TargetName="TileChrome" Property="Opacity" Value="0.45" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=TileChrome}" Value="True">
                                                        <Setter TargetName="RemoveShelfItemButton" Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=RemoveShelfItemButton}" Value="True">
                                                        <Setter TargetName="RemoveShelfItemButton" Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <Border x:Name="ShelfOverflowBadge"
                                        CornerRadius="10"
                                        Background="{StaticResource NotchPanelPressed}"
                                        Padding="8,3"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="ShelfOverflowText" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="ShelfDropOverlay"
                      Grid.RowSpan="2"
                      Visibility="Collapsed"
                      Opacity="0"
                      IsHitTestVisible="False">
                    <Border Width="360"
                            Height="96"
                            CornerRadius="22"
                            Background="{StaticResource NotchPanel}"
                            BorderBrush="{StaticResource NotchText}"
                            BorderThickness="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE8E5;" FontSize="21" Margin="0,0,12,0" />
                            <TextBlock Text="Drop to shelf" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </Grid>

                <Grid x:Name="MediaToastPanel" Grid.RowSpan="2" Visibility="Collapsed" Opacity="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42" Height="42" CornerRadius="8" Background="{StaticResource NotchPanel}" ClipToBounds="True" VerticalAlignment="Center">
                        <Grid>
                            <Image x:Name="MediaToastArtworkImage" Stretch="UniformToFill" Visibility="Collapsed" />
                            <TextBlock x:Name="MediaToastArtworkFallback"
                                       Text="Audio"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NotchMutedText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                        <TextBlock x:Name="MediaToastTitleText" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="MediaToastArtistText" FontSize="11" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MediaToastPreviousButton" Style="{StaticResource MediaIconButton}" ToolTip="Previous" AutomationProperties.Name="Toast previous track" Click="MediaPrevious_Click">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE100;" FontSize="14" />
                        </Button>
                        <Button x:Name="MediaToastPlayPauseButton" Style="{StaticResource MediaIconButton}" ToolTip="Play or pause" AutomationProperties.Name="Toast play or pause media" Click="MediaPlayPause_Click">
                            <TextBlock x:Name="MediaToastPlayPauseIcon" Style="{StaticResource IconText}" Text="&#xE768;" FontSize="14" />
                        </Button>
                        <Button x:Name="MediaToastNextButton" Style="{StaticResource MediaIconButton}" ToolTip="Next" AutomationProperties.Name="Toast next track" Click="MediaNext_Click">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE101;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid x:Name="NotificationToastPanel" Grid.RowSpan="2" Visibility="Collapsed" Opacity="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42" Height="42" CornerRadius="10" Background="{StaticResource NotchPanel}" ClipToBounds="True" VerticalAlignment="Center">
                        <Grid>
                            <Image x:Name="NotificationToastIconImage" Stretch="UniformToFill" Visibility="Collapsed" />
                            <TextBlock x:Name="NotificationToastIconFallback"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NotchText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <!-- Charger-connect polish swaps the generic status icon for a reusable battery fill glyph. -->
                            <Grid x:Name="ChargingToastBatteryGlyph"
                                  Width="34"
                                  Height="18"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True"
                                  Visibility="Collapsed">
                                <Border x:Name="ChargingToastBatteryShell"
                                        Width="30"
                                        Height="16"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        BorderBrush="{StaticResource NotchText}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="2">
                                    <Grid ClipToBounds="True">
                                        <Grid x:Name="ChargingToastBatteryFill"
                                              Width="0"
                                              HorizontalAlignment="Left"
                                              ClipToBounds="True">
                                            <Border x:Name="ChargingToastBatteryFillBrush"
                                                    Background="{StaticResource NotchText}"
                                                    CornerRadius="2" />
                                            <Border x:Name="ChargingToastTintSweep"
                                                    Width="12"
                                                    HorizontalAlignment="Left"
                                                    IsHitTestVisible="False"
                                                    Opacity="0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#00FFFFFF" Offset="0" />
                                                        <GradientStop Color="#B8FFFFFF" Offset="0.5" />
                                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="ChargingToastSweepTransform" X="-12" />
                                                </Border.RenderTransform>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <Border x:Name="ChargingToastBatteryTerminal"
                                        Width="3"
                                        Height="7"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource NotchText}"
                                        CornerRadius="0,1,1,0" />
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                        <DockPanel LastChildFill="True">
                            <TextBlock x:Name="NotificationToastTimeText" DockPanel.Dock="Right" FontSize="10" Foreground="{StaticResource NotchMutedText}" Margin="8,1,0,0" />
                            <TextBlock x:Name="NotificationToastTitleText" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <TextBlock x:Name="NotificationToastBodyText" FontSize="11" Foreground="{StaticResource NotchText}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                        <TextBlock x:Name="NotificationToastAppText" FontSize="10" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                    </StackPanel>

                    <TextBlock x:Name="ChargingToastPercentText"
                               Grid.Column="2"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Typography.NumeralAlignment="Tabular"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />

                    <StackPanel x:Name="NotificationToastActionsPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                        <Button x:Name="NotificationToastPrimaryActionButton" Padding="10,5" Margin="0,0,8,0" AutomationProperties.Name="Notification toast primary action" Click="NotificationToastPrimaryAction_Click">
                            <TextBlock x:Name="NotificationToastPrimaryActionText" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="90" />
                        </Button>
                        <Button x:Name="NotificationToastSecondaryActionButton" Padding="10,5" Margin="0" AutomationProperties.Name="Notification toast secondary action" Click="NotificationToastSecondaryAction_Click">
                            <TextBlock x:Name="NotificationToastSecondaryActionText" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="90" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
