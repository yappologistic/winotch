<Window x:Class="Winotch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:commandBar="clr-namespace:Winotch.CommandBar"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Winotch"
        mc:Ignorable="d"
        Title="Winotch"
        Width="680"
        Height="40"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <SolidColorBrush x:Key="NotchHitTestFill" Color="#01000000" />
        <Style x:Key="ModeTabButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource NotchPanelHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource NotchPanelPressed}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="{StaticResource NotchMutedText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Border x:Name="NotchShell"
                Width="220"
                Height="40"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Background="{StaticResource NotchBlack}"
                CornerRadius="0,0,20,20"
                Padding="10,4,10,6"
                SnapsToDevicePixels="True"
                AllowDrop="True"
                DragOver="Notch_DragOver"
                Drop="Notch_Drop"
                MouseEnter="Window_MouseEnter"
                MouseLeave="Window_MouseLeave">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.16" Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="HeaderRow" Height="28" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="ClockGroup" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border x:Name="LogoBadge" Width="28" Height="28" CornerRadius="14" Background="{StaticResource NotchPanel}" Margin="0,0,10,0">
                            <Grid>
                                <Ellipse x:Name="LogoAccountPicture" Visibility="Collapsed" />
                                <TextBlock x:Name="LogoFallbackText" Text="W" FontWeight="Bold" FontSize="14" LineHeight="18" LineStackingStrategy="BlockLineHeight" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <StackPanel>
                            <TextBlock x:Name="TimeText" FontSize="17" FontWeight="SemiBold" LineHeight="24" LineStackingStrategy="BlockLineHeight" MinWidth="82" />
                            <TextBlock x:Name="DateText" Foreground="{StaticResource NotchMutedText}" FontSize="12" LineHeight="15" Margin="0,1,0,0" />
                        </StackPanel>
                        <StackPanel x:Name="FocusLiveActivity" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed" Margin="12,0,0,0">
                            <Grid Width="26" Height="3" VerticalAlignment="Center" Margin="0,0,7,0" ClipToBounds="True">
                                <Border Background="{StaticResource NotchStroke}" CornerRadius="2" />
                                <Border x:Name="FocusLiveProgressFill" Width="0" HorizontalAlignment="Left" Background="{StaticResource NotchText}" CornerRadius="2" />
                            </Grid>
                            <TextBlock x:Name="FocusLiveRemainingText"
                                       Width="42"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextAlignment="Right"
                                       Typography.NumeralAlignment="Tabular" />
                        </StackPanel>
                        <StackPanel x:Name="CalendarLiveActivity" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed" Margin="10,0,0,0">
                            <Border CornerRadius="13" Background="{StaticResource NotchPanel}" Padding="8,4">
                                <TextBlock x:Name="CalendarLiveText"
                                           Width="90"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="StatusGroup" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE701;" Margin="0,0,6,0" />
                                <TextBlock x:Name="WifiText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" Margin="0,0,6,0" />
                                <TextBlock x:Name="VolumeText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="MicPillIndicator" CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="MicPillGlyph" Style="{StaticResource IconText}" Text="&#xE720;" Margin="0,0,6,0" />
                                <TextBlock x:Name="MicPillText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="26" Height="14" Margin="0,1,7,0">
                                    <Border Width="22"
                                            Height="12"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            BorderBrush="{StaticResource NotchText}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="2">
                                        <Grid ClipToBounds="True">
                                            <Border x:Name="BatteryFill" Width="16" HorizontalAlignment="Left" CornerRadius="1.5" />
                                        </Grid>
                                    </Border>
                                    <Border Width="3" Height="6" HorizontalAlignment="Right" VerticalAlignment="Center" Background="{StaticResource NotchText}" CornerRadius="0,1,1,0" />
                                </Grid>
                                <TextBlock x:Name="BatteryText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xEA8F;" Margin="0,0,6,0" />
                                <TextBlock x:Name="NotificationCountText" FontSize="12" FontWeight="SemiBold" Text="0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="DetailPanel" Grid.Row="1" Opacity="0" Margin="0,12,0,0" ClipToBounds="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="244" />
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid x:Name="SystemRail" Margin="0,0,18,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="System" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                        <StackPanel Grid.Row="1" Margin="0,12,0,0">
                            <TextBlock x:Name="LargeTimeText" FontSize="34" FontWeight="Light" LineHeight="42" Typography.NumeralAlignment="Tabular" />
                            <TextBlock x:Name="LargeDateText" FontSize="14" Foreground="{StaticResource NotchMutedText}" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Margin="0,22,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xEBA0;" FontSize="15" Margin="0,0,10,0" />
                                <TextBlock x:Name="BatteryDetailText" FontSize="13" FontWeight="SemiBold" />
                            </StackPanel>
                            <ProgressBar x:Name="BatteryBar" Style="{StaticResource ModernProgressBar}" Maximum="100" />
                        </StackPanel>
                        <ScrollViewer Grid.Row="3" Margin="0,22,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="SystemStatsSection" SnapsToDevicePixels="True">
                                <StackPanel x:Name="StatsRowsPanel" Visibility="Collapsed">
                                    <TextBlock Text="Stats" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" Margin="0,0,0,8" />
                                    <Grid x:Name="StatsCpuRow" Height="28" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="CPU" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                                        <TextBlock x:Name="StatsCpuValueText" Grid.Column="1" FontSize="12" TextAlignment="Right" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Typography.NumeralAlignment="Tabular" />
                                    </Grid>
                                    <Grid x:Name="StatsRamRow" Height="28" Margin="0,4,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="RAM" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                                        <TextBlock x:Name="StatsRamValueText" Grid.Column="1" FontSize="12" TextAlignment="Right" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Typography.NumeralAlignment="Tabular" />
                                    </Grid>
                                    <Grid x:Name="StatsNetRow" Height="28" Margin="0,4,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Net" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" />
                                        <TextBlock x:Name="StatsNetValueText" Grid.Column="1" FontSize="12" TextAlignment="Right" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Typography.NumeralAlignment="Tabular" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel x:Name="AgendaPanel" Margin="0,22,0,0">
                                    <TextBlock Text="Agenda" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                    <TextBlock x:Name="AgendaUpdatedText" FontSize="11" Foreground="{StaticResource NotchMutedText}" Margin="0,3,0,7" />
                                    <TextBlock x:Name="AgendaEmptyText"
                                               Text="No meetings in the next 24h"
                                               FontSize="12"
                                               Foreground="{StaticResource NotchMutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,2" />
                                    <ItemsControl x:Name="AgendaList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:CalendarAgendaRow}">
                                                <Grid Height="32" Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="58" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding TimeText}" FontSize="11" Foreground="{StaticResource NotchMutedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Title}" ToolTip="{Binding Title}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="6,0,8,0" />
                                                    <Button x:Name="AgendaJoinButton" Grid.Column="2" Padding="9,5" Tag="{Binding JoinUrl}" ToolTip="Join meeting" AutomationProperties.Name="Join meeting" Click="AgendaJoin_Click">
                                                        <TextBlock Text="Join" FontSize="11" />
                                                    </Button>
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding HasJoin}" Value="False">
                                                        <Setter TargetName="AgendaJoinButton" Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <local:ClipboardHistoryPanel x:Name="ClipboardPanel" Margin="0,16,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                        <Button x:Name="OpenSettingsButton" Grid.Row="4" HorizontalAlignment="Left" Padding="12,8" ToolTip="Settings" AutomationProperties.Name="Open Settings" Click="OpenSettings_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE713;" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="Settings" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Grid.Column="1" Background="{StaticResource NotchStroke}" Opacity="0.65" />

                    <Grid x:Name="ExpandedWorkspace" Grid.Column="2" Margin="18,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="48" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="76" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <StackPanel x:Name="ModeTabs" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Button x:Name="NowModeTab" Style="{StaticResource ModeTabButton}" Background="{StaticResource NotchHitTestFill}" BorderBrush="Transparent" BorderThickness="1" Padding="14,8" Margin="0,0,10,0" PreviewMouseLeftButtonDown="TimerModeTab_PreviewMouseLeftButtonDown" Click="TimerModeTab_Click">
                                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                                        <TextBlock x:Name="NowModeIcon" Style="{StaticResource IconText}" Text="&#xE121;" Foreground="{StaticResource NotchMutedText}" FontSize="14" Margin="0,0,8,0" />
                                        <TextBlock x:Name="NowModeText" Text="Timer" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ControlsModeTab" Style="{StaticResource ModeTabButton}" Background="{StaticResource NotchPanel}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" Padding="16,8" Margin="0,0,10,0" PreviewMouseLeftButtonDown="ControlsModeTab_PreviewMouseLeftButtonDown" Click="ControlsModeTab_Click">
                                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                                        <TextBlock x:Name="ControlsModeIcon" Style="{StaticResource IconText}" Text="&#xE9E9;" FontSize="14" Margin="0,0,8,0" />
                                        <TextBlock x:Name="ControlsModeText" Text="Controls" FontSize="13" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ActivityModeTab" Style="{StaticResource ModeTabButton}" Background="{StaticResource NotchHitTestFill}" BorderBrush="Transparent" BorderThickness="1" Padding="14,8" PreviewMouseLeftButtonDown="ActivityModeTab_PreviewMouseLeftButtonDown" Click="ActivityModeTab_Click">
                                    <StackPanel Orientation="Horizontal" IsHitTestVisible="False">
                                        <TextBlock x:Name="ActivityModeIcon" Style="{StaticResource IconText}" Text="&#xEA8F;" Foreground="{StaticResource NotchMutedText}" FontSize="14" Margin="0,0,8,0" />
                                        <TextBlock x:Name="ActivityModeText" Text="Activity" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource MediaIconButton}"
                                    Width="30"
                                    Height="30"
                                    Margin="0,1,0,0"
                                    ToolTip="Camera mirror"
                                    AutomationProperties.Name="Open camera mirror"
                                    Click="CameraMirror_Click">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE722;" FontSize="13" />
                            </Button>
                        </Grid>

                        <Grid x:Name="ModeContentHost" Grid.Row="1" ClipToBounds="True">
                            <Grid x:Name="ControlsTabContent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="340" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="AudioControlsSection" Background="{StaticResource NotchBlack}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
                                <ScrollViewer x:Name="AudioControlsScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="8" Background="{StaticResource NotchPanelRaised}">
                                            <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <TextBlock Text="Audio" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="Default output and live levels" FontSize="12" Foreground="{StaticResource NotchMutedText}" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Background="{StaticResource NotchPanel}" CornerRadius="8" Padding="8,7" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="Tools" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" Margin="0,0,0,7" />
                                            <StackPanel>
                                                <Button x:Name="ShelfButton" Padding="8,6" Margin="0,0,0,5" HorizontalContentAlignment="Left" ToolTip="Shelf" AutomationProperties.Name="Open shelf" Click="ShelfButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE8B7;" FontSize="12" Margin="0,0,5,0" />
                                                        <TextBlock Text="Shelf" FontSize="11" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="ColorPickerButton" Padding="8,6" Margin="0,0,0,5" HorizontalContentAlignment="Left" ToolTip="Color picker" AutomationProperties.Name="Open color picker" Click="ColorPicker_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE790;" FontSize="12" Margin="0,0,5,0" />
                                                        <TextBlock Text="Color" FontSize="11" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="TextScrubberButton" Padding="8,6" HorizontalContentAlignment="Left" ToolTip="Text scrubber" AutomationProperties.Name="Open text scrubber" Click="TextScrubber_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE8D2;" FontSize="12" Margin="0,0,5,0" />
                                                        <TextBlock Text="Text" FontSize="11" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource NotchPanel}" CornerRadius="8" Padding="8,7" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" FontSize="13" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="SelectedOutputDeviceText" Text="Output unavailable" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="Default output" FontSize="11" Foreground="{StaticResource NotchMutedText}" Margin="0,1,0,0" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Style="{StaticResource IconText}" Text="&#xE73E;" FontSize="11" Foreground="{StaticResource NotchMutedText}" Margin="8,0,0,0" />
                                        </Grid>
                                    </Border>

                                    <Grid Margin="0,2,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" />
                                        <TextBlock Grid.Column="1" Text="Master" FontSize="12" VerticalAlignment="Center" />
                                        <Slider x:Name="VolumeSlider" Grid.Column="2" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="100" ValueChanged="VolumeSlider_ValueChanged" />
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="MicRowGlyph" Style="{StaticResource IconText}" Text="&#xE720;" />
                                        <TextBlock x:Name="MicRowStateText" Grid.Column="1" FontSize="12" VerticalAlignment="Center" />
                                        <Button x:Name="MicMuteButton" Grid.Column="2" Padding="10,5" Click="MicMute_Click">
                                            <TextBlock x:Name="MicMuteButtonText" FontSize="11" />
                                        </Button>
                                    </Grid>

                                    <Border x:Name="BrightnessBlock" Background="{StaticResource NotchPanel}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,10" Visibility="Collapsed">
                                        <ItemsControl x:Name="BrightnessList" Margin="10,6,10,2">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Height="31" Margin="0,0,0,5" ToolTip="{Binding Name}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="32" />
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE706;" FontSize="13" />
                                                        <Slider Grid.Column="1" Style="{StaticResource ModernSlider}" AutomationProperties.Name="{Binding Name}" Minimum="0" Maximum="100" Value="{Binding Percent}" ValueChanged="BrightnessSlider_ValueChanged" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <Button x:Name="AudioMoreToggleButton" Padding="12,7" HorizontalContentAlignment="Stretch" Click="AudioMoreToggle_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="More" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock x:Name="AudioMoreChevron" Grid.Column="1" Style="{StaticResource IconText}" Text="&#xE70D;" FontSize="11" Margin="10,1,0,0" />
                                        </Grid>
                                    </Button>
                                    <StackPanel x:Name="AudioMorePanel" Visibility="Collapsed" Margin="0,8,0,0">
                                            <TextBlock Text="Outputs" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                            <ItemsControl x:Name="OutputDeviceList" Margin="0,6,0,10">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Padding="8,6" Margin="0,0,0,5" HorizontalContentAlignment="Stretch" Click="OutputDevice_Click" ToolTip="{Binding Name}">
                                                            <Grid HorizontalAlignment="Stretch">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="20" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="18" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" FontSize="13" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="2" Text="&#xE73E;" FontSize="11">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource IconText}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsDefault}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Hidden" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <StackPanel x:Name="AudioSessionMixerSection" Margin="0,0,0,10">
                                        <TextBlock Text="Apps" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                        <TextBlock x:Name="NoAudioSessionsText" Text="No active audio sessions" FontSize="12" Foreground="{StaticResource NotchMutedText}" Margin="0,5,0,6" />
                                                <ScrollViewer x:Name="AudioSessionScroll" Height="86" Margin="0,4,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="AudioSessionList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Height="31" Margin="0,0,0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="24" />
                                                                <ColumnDefinition Width="72" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="32" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Width="22" Height="22" VerticalAlignment="Center">
                                                                <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" FontSize="12" HorizontalAlignment="Center" />
                                                                <Image Source="{Binding Icon}" Width="22" Height="22" Stretch="UniformToFill">
                                                                    <Image.Style>
                                                                        <Style TargetType="Image">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Image.Style>
                                                                </Image>
                                                            </Grid>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" ToolTip="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                            <Slider Grid.Column="2" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="100" Value="{Binding Volume}" ValueChanged="AudioSessionVolumeSlider_ValueChanged" />
                                                            <Button Grid.Column="3" Style="{StaticResource MediaIconButton}" Margin="6,0,0,0" ToolTip="Mute app" Click="AudioSessionMute_Click">
                                                                <TextBlock FontSize="12">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource IconText}">
                                                                            <Setter Property="Text" Value="&#xE767;" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                                                                    <Setter Property="Text" Value="&#xE74F;" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>

                                            <Border x:Name="WifiControlsSection" Background="{StaticResource NotchPanel}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" CornerRadius="8" Padding="12">
                                                <StackPanel>
                                    <TextBlock Text="Wi-Fi" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                    <TextBlock x:Name="WifiStateText" FontSize="12" Foreground="{StaticResource NotchText}" Margin="0,5,0,6" TextWrapping="Wrap" />
                                    <ListBox x:Name="WifiList"
                                             Height="42"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{StaticResource NotchText}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ItemContainerStyle="{StaticResource NotchListBoxItem}" />
                                    <Button x:Name="ConnectWifiButton" Content="Connect" HorizontalAlignment="Left" Margin="0,8,0,0" Click="ConnectWifi_Click" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                                </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <Grid x:Name="TimerColumn" Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border x:Name="NowSection" Background="{StaticResource NotchBlack}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Timer" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" Margin="0,0,0,8" />
                                        <Border x:Name="FocusTimerSection" Background="{StaticResource NotchPanel}" CornerRadius="8" Padding="10">
                                            <StackPanel>
                                                <TextBlock Text="Pomodoro" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                                <StackPanel x:Name="FocusSetupPanel" Margin="0,7,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="25/5" Padding="9,5" Margin="0,0,6,0" Click="FocusShortPreset_Click" />
                                                        <Button Content="50/10" Padding="9,5" Margin="0,0,8,0" Click="FocusLongPreset_Click" />
                                                        <TextBox x:Name="FocusCustomMinutesBox" Width="48" Height="28" Padding="5,3" Style="{StaticResource NotchTextBox}" TextAlignment="Center" ToolTip="Custom focus minutes" Typography.NumeralAlignment="Tabular" />
                                                    </StackPanel>
                                                    <DockPanel Margin="0,8,0,0" LastChildFill="False">
                                                        <CheckBox x:Name="FocusAutoCycleCheckBox" Content="Auto-cycle" Foreground="{StaticResource NotchMutedText}" FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                        <Button Content="Start" Padding="12,5" Click="FocusStart_Click" />
                                                    </DockPanel>
                                                    <TextBlock x:Name="FocusValidationText" FontSize="11" Foreground="{StaticResource NotchDanger}" Visibility="Collapsed" Margin="0,5,0,0" />
                                                </StackPanel>
                                                <StackPanel Margin="0,12,0,0">
                                                    <TextBlock Text="Live timer" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" Margin="0,0,0,7" />
                                                    <UniformGrid x:Name="LiveTimerPresetPanel" Columns="3">
                                                        <Button Content="5 min" Tag="5" FontSize="11" Padding="3,5" Margin="0,0,6,0" Click="StartTransientLiveTimer_Click" />
                                                        <Button Content="10 min" Tag="10" FontSize="11" Padding="3,5" Margin="0,0,6,0" Click="StartTransientLiveTimer_Click" />
                                                        <Button Content="15 min" Tag="15" FontSize="11" Padding="3,5" Click="StartTransientLiveTimer_Click" />
                                                    </UniformGrid>
                                                    <StackPanel x:Name="LiveTimerRunningPanel" Visibility="Collapsed">
                                                        <DockPanel LastChildFill="True">
                                                            <TextBlock x:Name="LiveTimerStateText" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                                            <TextBlock x:Name="LiveTimerRemainingText" DockPanel.Dock="Right" FontSize="20" FontWeight="SemiBold" TextAlignment="Right" Typography.NumeralAlignment="Tabular" />
                                                        </DockPanel>
                                                        <ProgressBar x:Name="LiveTimerProgressBar" Style="{StaticResource ModernProgressBar}" Height="4" Margin="0,6,0,8" Maximum="100" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button x:Name="LiveTimerPauseResumeButton" Content="Pause" Padding="9,5" Margin="0,0,6,0" Click="PauseResumeLiveTimer_Click" />
                                                            <Button Content="Cancel" Padding="9,5" Click="CancelLiveTimer_Click" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel x:Name="FocusRunningPanel" Visibility="Collapsed" Margin="0,7,0,0">
                                                    <DockPanel LastChildFill="True">
                                                        <TextBlock x:Name="FocusPhaseText" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                                        <TextBlock x:Name="FocusRemainingText" DockPanel.Dock="Right" FontSize="22" FontWeight="SemiBold" TextAlignment="Right" Typography.NumeralAlignment="Tabular" />
                                                    </DockPanel>
                                                    <ProgressBar x:Name="FocusProgressBar" Style="{StaticResource ModernProgressBar}" Height="4" Margin="0,6,0,8" Maximum="100" />
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button x:Name="FocusPauseResumeButton" Content="Pause" Padding="9,5" Margin="0,0,6,0" Click="FocusPauseResume_Click" />
                                                        <Button Content="Skip" Padding="9,5" Margin="0,0,6,0" Click="FocusSkip_Click" />
                                                        <Button Content="Stop" Padding="9,5" Click="FocusStop_Click" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="NowPlayingSection" Grid.Row="1" Background="{StaticResource NotchBlack}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Now playing" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" Margin="0,0,0,8" />
                                        <Grid x:Name="MediaPanel" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="54" Height="54" CornerRadius="9" Background="{StaticResource NotchPanelRaised}" ClipToBounds="True">
                                                <Grid>
                                                    <Image x:Name="MediaArtworkImage" Stretch="UniformToFill" Visibility="Collapsed" />
                                                    <TextBlock x:Name="MediaArtworkFallback" Text="Audio" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock x:Name="MediaTitleText" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock x:Name="MediaArtistText" FontSize="12" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" Margin="0,1,0,7" />
                                                <StackPanel Orientation="Horizontal">
                                                    <Button x:Name="MediaPreviousButton" Style="{StaticResource MediaIconButton}" ToolTip="Previous" AutomationProperties.Name="Previous track" Click="MediaPrevious_Click">
                                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE100;" FontSize="14" />
                                                    </Button>
                                                    <Button x:Name="MediaPlayPauseButton" Style="{StaticResource MediaIconButton}" ToolTip="Play or pause" AutomationProperties.Name="Play or pause media" Click="MediaPlayPause_Click">
                                                        <TextBlock x:Name="MediaPlayPauseIcon" Style="{StaticResource IconText}" Text="&#xE768;" FontSize="14" />
                                                    </Button>
                                                    <Button x:Name="MediaNextButton" Style="{StaticResource MediaIconButton}" ToolTip="Next" AutomationProperties.Name="Next track" Click="MediaNext_Click">
                                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE101;" FontSize="14" />
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock x:Name="NoMediaText"
                                                   Text="No media playing"
                                                   FontSize="12"
                                                   Foreground="{StaticResource NotchMutedText}"
                                                   Visibility="Collapsed"
                                                   Margin="0,0,0,10" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            </Grid>
                            <Border x:Name="ActivitySection" Visibility="Collapsed" Background="{StaticResource NotchBlack}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" CornerRadius="8" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Activity" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                                    <ListBox x:Name="NotificationList"
                                             Height="258"
                                             Margin="0,10,0,0"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{StaticResource NotchText}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ItemContainerStyle="{StaticResource NotchListBoxItem}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type local:NotificationItem}">
                                                <StackPanel MaxHeight="85" ClipToBounds="True">
                                                    <TextBlock Text="{Binding App}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                                    <TextBlock Text="{Binding Body}" FontSize="11" LineHeight="16" MaxHeight="48" ClipToBounds="True" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border x:Name="ActivityStrip" Grid.Row="2" Background="{StaticResource NotchBlack}" BorderBrush="{StaticResource NotchStroke}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="32" Height="32" CornerRadius="8" Background="{StaticResource NotchPanelRaised}" Margin="0,0,10,0">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xEA8F;" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Notifications" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock x:Name="NotificationStateText" FontSize="12" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <Button Grid.Column="2" Padding="12,7" Margin="12,0,8,0" AutomationProperties.Name="View notifications" Click="ViewNotifications_Click">
                                    <TextBlock Text="View" FontSize="12" FontWeight="SemiBold" />
                                </Button>
                                <Button x:Name="CopyDiagnosticsButton" Grid.Column="3" Padding="12,7" ToolTip="Copy diagnostics" AutomationProperties.Name="Copy diagnostics" Click="CopyDiagnostics_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE8C8;" FontSize="13" Margin="0,0,8,0" />
                                        <TextBlock Text="Copy diagnostics" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <commandBar:CommandBarPanel x:Name="CommandBarPanel"
                                            Grid.RowSpan="2"
                                            Margin="8,8,8,12"
                                            Visibility="Collapsed"
                                            Opacity="0" />

                <Grid x:Name="MediaToastPanel" Grid.RowSpan="2" Visibility="Collapsed" Opacity="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42" Height="42" CornerRadius="8" Background="{StaticResource NotchPanel}" ClipToBounds="True" VerticalAlignment="Center">
                        <Grid>
                            <Image x:Name="MediaToastArtworkImage" Stretch="UniformToFill" Visibility="Collapsed" />
                            <TextBlock x:Name="MediaToastArtworkFallback"
                                       Text="Audio"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NotchMutedText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                        <TextBlock x:Name="MediaToastTitleText" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="MediaToastArtistText" FontSize="11" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MediaToastPreviousButton" Style="{StaticResource MediaIconButton}" ToolTip="Previous" AutomationProperties.Name="Toast previous track" Click="MediaPrevious_Click">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE100;" FontSize="14" />
                        </Button>
                        <Button x:Name="MediaToastPlayPauseButton" Style="{StaticResource MediaIconButton}" ToolTip="Play or pause" AutomationProperties.Name="Toast play or pause media" Click="MediaPlayPause_Click">
                            <TextBlock x:Name="MediaToastPlayPauseIcon" Style="{StaticResource IconText}" Text="&#xE768;" FontSize="14" />
                        </Button>
                        <Button x:Name="MediaToastNextButton" Style="{StaticResource MediaIconButton}" ToolTip="Next" AutomationProperties.Name="Toast next track" Click="MediaNext_Click">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE101;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>

                <local:LiveStripPanel x:Name="LiveStrip"
                                      Grid.RowSpan="2"
                                      Visibility="Collapsed"
                                      Opacity="0"
                                      VerticalAlignment="Center" />

                <Grid x:Name="NotificationToastPanel" Grid.RowSpan="2" Visibility="Collapsed" Opacity="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42" Height="42" CornerRadius="10" Background="{StaticResource NotchPanel}" ClipToBounds="True" VerticalAlignment="Center">
                        <Grid>
                            <Image x:Name="NotificationToastIconImage" Stretch="UniformToFill" Visibility="Collapsed" />
                            <TextBlock x:Name="NotificationToastIconFallback"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NotchText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <!-- Charger-connect polish swaps the generic status icon for a reusable battery fill glyph. -->
                            <Grid x:Name="ChargingToastBatteryGlyph"
                                  Width="34"
                                  Height="18"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True"
                                  Visibility="Collapsed">
                                <Border x:Name="ChargingToastBatteryShell"
                                        Width="30"
                                        Height="16"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        BorderBrush="{StaticResource NotchText}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="2">
                                    <Grid ClipToBounds="True">
                                        <Grid x:Name="ChargingToastBatteryFill"
                                              Width="0"
                                              HorizontalAlignment="Left"
                                              ClipToBounds="True">
                                            <Border x:Name="ChargingToastBatteryFillBrush"
                                                    Background="{StaticResource NotchText}"
                                                    CornerRadius="2" />
                                            <Border x:Name="ChargingToastTintSweep"
                                                    Width="12"
                                                    HorizontalAlignment="Left"
                                                    IsHitTestVisible="False"
                                                    Opacity="0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#00FFFFFF" Offset="0" />
                                                        <GradientStop Color="#B8FFFFFF" Offset="0.5" />
                                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.RenderTransform>
                                                    <TranslateTransform x:Name="ChargingToastSweepTransform" X="-12" />
                                                </Border.RenderTransform>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                                <Border x:Name="ChargingToastBatteryTerminal"
                                        Width="3"
                                        Height="7"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource NotchText}"
                                        CornerRadius="0,1,1,0" />
                            </Grid>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                        <DockPanel LastChildFill="True">
                            <TextBlock x:Name="NotificationToastTimeText" DockPanel.Dock="Right" FontSize="10" Foreground="{StaticResource NotchMutedText}" Margin="8,1,0,0" />
                            <TextBlock x:Name="NotificationToastTitleText" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <TextBlock x:Name="NotificationToastBodyText" FontSize="11" Foreground="{StaticResource NotchText}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                        <TextBlock x:Name="NotificationToastAppText" FontSize="10" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                    </StackPanel>

                    <TextBlock x:Name="ChargingToastPercentText"
                               Grid.Column="2"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Typography.NumeralAlignment="Tabular"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />

                    <StackPanel x:Name="NotificationToastActionsPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                        <Button x:Name="NotificationToastPrimaryActionButton" Padding="10,5" Margin="0,0,8,0" AutomationProperties.Name="Notification toast primary action" Click="NotificationToastPrimaryAction_Click">
                            <TextBlock x:Name="NotificationToastPrimaryActionText" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="90" />
                        </Button>
                        <Button x:Name="NotificationToastSecondaryActionButton" Padding="10,5" Margin="0" AutomationProperties.Name="Notification toast secondary action" Click="NotificationToastSecondaryAction_Click">
                            <TextBlock x:Name="NotificationToastSecondaryActionText" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="90" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
