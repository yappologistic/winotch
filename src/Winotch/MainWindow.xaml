<Window x:Class="Winotch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Winotch"
        mc:Ignorable="d"
        Title="Winotch"
        Width="680"
        Height="40"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">
    <Grid Background="Transparent">
        <Border x:Name="NotchShell"
                Width="220"
                Height="40"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Background="{StaticResource NotchBlack}"
                CornerRadius="0,0,20,20"
                Padding="10,4,10,6"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.16" Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="HeaderRow" Height="28" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="ClockGroup" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border x:Name="LogoBadge" Width="28" Height="28" CornerRadius="14" Background="{StaticResource NotchPanel}" Margin="0,0,10,0">
                            <Grid>
                                <Ellipse x:Name="LogoAccountPicture" Visibility="Collapsed" />
                                <TextBlock x:Name="LogoFallbackText" Text="W" FontWeight="Bold" FontSize="14" LineHeight="18" LineStackingStrategy="BlockLineHeight" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <StackPanel>
                            <TextBlock x:Name="TimeText" FontSize="17" FontWeight="SemiBold" LineHeight="24" LineStackingStrategy="BlockLineHeight" MinWidth="82" />
                            <TextBlock x:Name="DateText" Foreground="{StaticResource NotchMutedText}" FontSize="12" LineHeight="15" Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="StatusGroup" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE701;" Margin="0,0,6,0" />
                                <TextBlock x:Name="WifiText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xE767;" Margin="0,0,6,0" />
                                <TextBlock x:Name="VolumeText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="26" Height="14" Margin="0,1,7,0">
                                    <Border Width="22"
                                            Height="12"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            BorderBrush="{StaticResource NotchText}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="2">
                                        <Grid ClipToBounds="True">
                                            <Border x:Name="BatteryFill" Width="16" HorizontalAlignment="Left" CornerRadius="1.5" />
                                        </Grid>
                                    </Border>
                                    <Border Width="3" Height="6" HorizontalAlignment="Right" VerticalAlignment="Center" Background="{StaticResource NotchText}" CornerRadius="0,1,1,0" />
                                </Grid>
                                <TextBlock x:Name="BatteryText" FontSize="12" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="17" Background="{StaticResource NotchPanel}" Padding="11,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconText}" Text="&#xEA8F;" Margin="0,0,6,0" />
                                <TextBlock x:Name="NotificationCountText" FontSize="12" FontWeight="SemiBold" Text="0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="DetailPanel" Grid.Row="1" Opacity="0" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="2,0,22,0">
                        <TextBlock Text="System" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                        <TextBlock x:Name="LargeTimeText" FontSize="38" FontWeight="Light" Margin="0,4,0,0" />
                        <TextBlock x:Name="LargeDateText" FontSize="14" Foreground="{StaticResource NotchMutedText}" />
                        <ProgressBar x:Name="BatteryBar" Style="{StaticResource ModernProgressBar}" Margin="0,16,0,8" Maximum="100" />
                        <TextBlock x:Name="BatteryDetailText" FontSize="12" Foreground="{StaticResource NotchMutedText}" />
                        <local:ClipboardHistoryPanel x:Name="ClipboardPanel" Margin="0,18,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,22,0">
                        <Grid x:Name="MediaPanel" Visibility="Collapsed" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" CornerRadius="9" Background="{StaticResource NotchPanel}" ClipToBounds="True">
                                <Grid>
                                    <Image x:Name="MediaArtworkImage" Stretch="UniformToFill" Visibility="Collapsed" />
                                    <TextBlock x:Name="MediaArtworkFallback"
                                               Text="Audio"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource NotchMutedText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="MediaTitleText" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="MediaArtistText" FontSize="12" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" Margin="0,1,0,7" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="MediaPreviousButton" Style="{StaticResource MediaIconButton}" ToolTip="Previous" AutomationProperties.Name="Previous track" Click="MediaPrevious_Click">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE100;" FontSize="14" />
                                    </Button>
                                    <Button x:Name="MediaPlayPauseButton" Style="{StaticResource MediaIconButton}" ToolTip="Play or pause" AutomationProperties.Name="Play or pause media" Click="MediaPlayPause_Click">
                                        <TextBlock x:Name="MediaPlayPauseIcon" Style="{StaticResource IconText}" Text="&#xE768;" FontSize="14" />
                                    </Button>
                                    <Button x:Name="MediaNextButton" Style="{StaticResource MediaIconButton}" ToolTip="Next" AutomationProperties.Name="Next track" Click="MediaNext_Click">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE101;" FontSize="14" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Notifications" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                        <TextBlock x:Name="NotificationStateText" FontSize="12" Foreground="{StaticResource NotchMutedText}" Margin="0,4,0,8" />
                        <ListBox x:Name="NotificationList"
                                 Height="110"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{StaticResource NotchText}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 ItemContainerStyle="{StaticResource NotchListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontSize="12"
                                               LineHeight="17"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sound" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                        <Slider x:Name="VolumeSlider" Style="{StaticResource ModernSlider}" Minimum="0" Maximum="100" Margin="0,8,0,16" ValueChanged="VolumeSlider_ValueChanged" />
                        <TextBlock Text="Wi-Fi" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource NotchMutedText}" />
                        <TextBlock x:Name="WifiStateText" FontSize="12" Foreground="{StaticResource NotchText}" Margin="0,5,0,6" TextWrapping="Wrap" />
                        <ListBox x:Name="WifiList"
                                 Height="42"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{StaticResource NotchText}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 ItemContainerStyle="{StaticResource NotchListBoxItem}" />
                        <Button x:Name="ConnectWifiButton" Content="Connect" HorizontalAlignment="Left" Margin="0,8,0,0" Click="ConnectWifi_Click" />
                    </StackPanel>
                </Grid>

                <Grid x:Name="MediaToastPanel" Grid.RowSpan="2" Visibility="Collapsed" Opacity="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42" Height="42" CornerRadius="8" Background="{StaticResource NotchPanel}" ClipToBounds="True" VerticalAlignment="Center">
                        <Grid>
                            <Image x:Name="MediaToastArtworkImage" Stretch="UniformToFill" Visibility="Collapsed" />
                            <TextBlock x:Name="MediaToastArtworkFallback"
                                       Text="Audio"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NotchMutedText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                        <TextBlock x:Name="MediaToastTitleText" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="MediaToastArtistText" FontSize="11" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="MediaToastPreviousButton" Style="{StaticResource MediaIconButton}" ToolTip="Previous" AutomationProperties.Name="Toast previous track" Click="MediaPrevious_Click">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE100;" FontSize="14" />
                        </Button>
                        <Button x:Name="MediaToastPlayPauseButton" Style="{StaticResource MediaIconButton}" ToolTip="Play or pause" AutomationProperties.Name="Toast play or pause media" Click="MediaPlayPause_Click">
                            <TextBlock x:Name="MediaToastPlayPauseIcon" Style="{StaticResource IconText}" Text="&#xE768;" FontSize="14" />
                        </Button>
                        <Button x:Name="MediaToastNextButton" Style="{StaticResource MediaIconButton}" ToolTip="Next" AutomationProperties.Name="Toast next track" Click="MediaNext_Click">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE101;" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid x:Name="NotificationToastPanel" Grid.RowSpan="2" Visibility="Collapsed" Opacity="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="42" Height="42" CornerRadius="10" Background="{StaticResource NotchPanel}" ClipToBounds="True" VerticalAlignment="Center">
                        <Grid>
                            <Image x:Name="NotificationToastIconImage" Stretch="UniformToFill" Visibility="Collapsed" />
                            <TextBlock x:Name="NotificationToastIconFallback"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NotchText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,12,0" VerticalAlignment="Center">
                        <DockPanel LastChildFill="True">
                            <TextBlock x:Name="NotificationToastTimeText" DockPanel.Dock="Right" FontSize="10" Foreground="{StaticResource NotchMutedText}" Margin="8,1,0,0" />
                            <TextBlock x:Name="NotificationToastTitleText" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                        <TextBlock x:Name="NotificationToastBodyText" FontSize="11" Foreground="{StaticResource NotchText}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                        <TextBlock x:Name="NotificationToastAppText" FontSize="10" Foreground="{StaticResource NotchMutedText}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel x:Name="NotificationToastActionsPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                        <Button x:Name="NotificationToastPrimaryActionButton" Padding="10,5" Margin="0,0,8,0" AutomationProperties.Name="Notification toast primary action" Click="NotificationToastPrimaryAction_Click">
                            <TextBlock x:Name="NotificationToastPrimaryActionText" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="90" />
                        </Button>
                        <Button x:Name="NotificationToastSecondaryActionButton" Padding="10,5" Margin="0" AutomationProperties.Name="Notification toast secondary action" Click="NotificationToastSecondaryAction_Click">
                            <TextBlock x:Name="NotificationToastSecondaryActionText" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="90" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
