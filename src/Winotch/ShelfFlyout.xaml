<Window x:Class="Winotch.ShelfFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Winotch"
        Title="Shelf"
        Width="430"
        Height="280"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">
    <Border x:Name="FlyoutChrome"
            Padding="10"
            CornerRadius="24"
            Background="{StaticResource NotchBlack}"
            BorderBrush="{StaticResource NotchStroke}"
            BorderThickness="1"
            RenderTransformOrigin="0.5,0">
        <Border.RenderTransform>
            <ScaleTransform x:Name="FlyoutScale" ScaleX="0.96" ScaleY="0.96" />
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Margin="2,0,2,8">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8B7;" FontSize="15" Margin="0,0,8,0" />
                    <TextBlock Text="Shelf" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Width="28" Height="28" Padding="0" Margin="0,0,8,0" ToolTip="Clear shelf" AutomationProperties.Name="Clear shelf" Click="ClearButton_Click">
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE894;" FontSize="12" />
                    </Button>
                    <Button Style="{StaticResource MediaIconButton}" Width="28" Height="28" Margin="0" ToolTip="Close" AutomationProperties.Name="Close shelf" Click="CloseButton_Click">
                        <TextBlock Style="{StaticResource IconText}" Text="&#xE711;" FontSize="10" />
                    </Button>
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <TextBlock x:Name="EmptyText"
                           Text="Drop files, text, links, or images onto the notch"
                           FontSize="12"
                           Foreground="{StaticResource NotchMutedText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="22" />
                <ListBox x:Name="ShelfList"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{StaticResource NotchText}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ItemContainerStyle="{StaticResource NotchListBoxItem}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:ShelfRow}">
                            <Grid MinHeight="38" Margin="0,1" PreviewMouseMove="ShelfRow_PreviewMouseMove">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="34" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Glyph}" Style="{StaticResource IconText}" FontSize="14" VerticalAlignment="Center" />
                                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock x:Name="PreviewText" Text="{Binding Preview}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <Image x:Name="ThumbnailImage" Source="{Binding Thumbnail}" MaxWidth="62" MaxHeight="44" Stretch="Uniform" HorizontalAlignment="Left" Visibility="Collapsed" />
                                </Grid>
                                <Button Grid.Column="2" Width="26" Height="26" Padding="0" Tag="{Binding Item}" ToolTip="Copy" AutomationProperties.Name="Copy shelf item" Click="CopyButton_Click">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8C8;" FontSize="11" />
                                </Button>
                                <Button Grid.Column="3" Width="26" Height="26" Padding="0" Tag="{Binding Item}" ToolTip="Open" AutomationProperties.Name="Open shelf item" Click="OpenButton_Click">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8A7;" FontSize="11" />
                                </Button>
                                <Button Grid.Column="4" Width="26" Height="26" Padding="0" Tag="{Binding Item}" ToolTip="Remove" AutomationProperties.Name="Remove shelf item" Click="RemoveButton_Click">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE74D;" FontSize="11" />
                                </Button>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                                    <Setter TargetName="PreviewText" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="ThumbnailImage" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Window>
