<local:FluentWindow
    x:Class="Winotch.ShelfFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Winotch"
    Title="Shelf"
    AttachToTopEdge="False"
    BottomCornerRadius="24">

    <Border
        x:Name="FlyoutChrome"
        Padding="12"
        Background="{StaticResource NotchPanel}"
        BorderBrush="{StaticResource NotchStroke}"
        BorderThickness="{StaticResource WinotchHairline}"
        CornerRadius="24"
        KeyDown="FlyoutChrome_KeyDown">
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid
                x:Name="HeaderDragArea"
                Padding="4,0,2,0"
                Background="Transparent"
                ColumnSpacing="8"
                PointerPressed="HeaderDragArea_PointerPressed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="30"
                    Height="30"
                    Background="{StaticResource NotchPanelRaised}"
                    CornerRadius="15">
                    <FontIcon
                        FontFamily="{StaticResource WinotchIconFont}"
                        FontSize="15"
                        Glyph="&#xE8B7;"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                    <TextBlock Style="{StaticResource WinotchBodyText}" Text="Shelf" />
                    <TextBlock Style="{StaticResource WinotchCaptionText}" Text="Ready to move anywhere" />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    Width="32"
                    Height="32"
                    AutomationProperties.Name="Close shelf"
                    Click="CloseButton_Click"
                    Style="{StaticResource WinotchIconButton}"
                    ToolTipService.ToolTip="Close">
                    <FontIcon FontFamily="{StaticResource WinotchIconFont}" FontSize="11" Glyph="&#xE711;" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="2,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="ItemCountText"
                    Style="{StaticResource WinotchCaptionText}"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="ClearButton"
                    Grid.Column="1"
                    Padding="12,6"
                    AutomationProperties.Name="Clear shelf"
                    Click="ClearButton_Click"
                    Content="Clear"
                    CornerRadius="12"
                    ToolTipService.ToolTip="Clear shelf" />
            </Grid>

            <Grid Grid.Row="2">
                <Border
                    x:Name="EmptyState"
                    Margin="2"
                    Background="{StaticResource NotchPanel}"
                    CornerRadius="16">
                    <StackPanel
                        MaxWidth="280"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon
                            FontFamily="{StaticResource WinotchIconFont}"
                            FontSize="24"
                            Foreground="{StaticResource NotchMutedText}"
                            Glyph="&#xE7C3;" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource WinotchBodyText}"
                            Text="Drop something on the notch" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="{StaticResource NotchMutedText}"
                            Text="Files, text, links, and images stay in memory until you clear them."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ListView
                    x:Name="ShelfList"
                    Background="Transparent"
                    BorderThickness="0"
                    IsItemClickEnabled="False"
                    ItemContainerStyle="{StaticResource NotchListBoxItem}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ShelfRow">
                            <Grid
                                MinHeight="46"
                                CanDrag="True"
                                ColumnSpacing="8"
                                DragStarting="ShelfRow_DragStarting"
                                DropCompleted="ShelfRow_DropCompleted">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Width="30"
                                    Height="30"
                                    Background="{StaticResource NotchPanelRaised}"
                                    CornerRadius="9">
                                    <Grid>
                                        <Image
                                            Width="22"
                                            Height="22"
                                            Source="{x:Bind Icon}"
                                            Stretch="Uniform"
                                            Visibility="{x:Bind IconVisibility}" />
                                        <FontIcon
                                            FontFamily="{StaticResource WinotchIconFont}"
                                            FontSize="15"
                                            Glyph="{x:Bind Glyph}"
                                            Visibility="{x:Bind GlyphVisibility}" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" Margin="2,0,4,0" VerticalAlignment="Center">
                                    <TextBlock
                                        Style="{StaticResource WinotchBodyText}"
                                        Text="{x:Bind Preview}"
                                        Visibility="{x:Bind PreviewVisibility}" />
                                    <Image
                                        MaxWidth="76"
                                        MaxHeight="42"
                                        HorizontalAlignment="Left"
                                        Source="{x:Bind Thumbnail}"
                                        Stretch="Uniform"
                                        Visibility="{x:Bind ThumbnailVisibility}" />
                                </Grid>

                                <Button
                                    Grid.Column="2"
                                    AutomationProperties.Name="Copy shelf item"
                                    Click="CopyButton_Click"
                                    Style="{StaticResource WinotchIconButton}"
                                    Tag="{x:Bind Item}"
                                    ToolTipService.ToolTip="Copy">
                                    <FontIcon FontFamily="{StaticResource WinotchIconFont}" FontSize="13" Glyph="&#xE8C8;" />
                                </Button>
                                <Button
                                    Grid.Column="3"
                                    AutomationProperties.Name="Open shelf item"
                                    Click="OpenButton_Click"
                                    IsEnabled="{x:Bind CanOpen}"
                                    Style="{StaticResource WinotchIconButton}"
                                    Tag="{x:Bind Item}"
                                    ToolTipService.ToolTip="Open">
                                    <FontIcon FontFamily="{StaticResource WinotchIconFont}" FontSize="13" Glyph="&#xE8A7;" />
                                </Button>
                                <Button
                                    Grid.Column="4"
                                    AutomationProperties.Name="Remove shelf item"
                                    Click="RemoveButton_Click"
                                    Style="{StaticResource WinotchIconButton}"
                                    Tag="{x:Bind Item}"
                                    ToolTipService.ToolTip="Remove">
                                    <FontIcon FontFamily="{StaticResource WinotchIconFont}" FontSize="13" Glyph="&#xE74D;" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Border>
</local:FluentWindow>
